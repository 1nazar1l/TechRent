@using Microsoft.AspNetCore.Identity
@using System.Globalization
@model TechRent.Models.Entities.Equipment
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = Model?.Name ?? "Product Details";
    ViewData["css"] = "product";
    ViewData["nav_pos"] = "left";
    ViewData["header"] = "with_search";
}

<main class="main-content">
    <div class="product-container">
        <!-- Breadcrumbs -->
        <nav class="breadcrumb">
            <a href="@Url.Action("Index", "Home")" class="breadcrumb-link">Home</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <a href="@Url.Action("Index", "Equipment")" class="breadcrumb-link">Catalog</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span class="breadcrumb-current">@Model?.Category?.Name</span>
        </nav>

        @if (Model != null)
        {
            var averageRating = Model.Reviews != null && Model.Reviews.Any()
            ? Model.Reviews.Average(r => r.Rating).ToString("F1")
            : "0.0";
            var reviewCount = Model.Reviews?.Count ?? 0;
            var roundedRating = Model.Reviews != null && Model.Reviews.Any()
            ? (int)Math.Round(Model.Reviews.Average(r => r.Rating))
            : 0;

            <div class="product-layout">
                <!-- Left Column: Gallery -->
                <div class="product-gallery">
                    <!-- Main Image -->
                    <div class="gallery-main">
                        <div class="gallery-main-image">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" alt="@Model.Name">
                            }
                            else
                            {
                                <div style="width: 100%; height: 400px; background: #f1f5f9; display: flex; align-items: center; justify-content: center;">
                                    <span class="material-symbols-outlined" style="font-size: 80px; color: #94a3b8;">construction</span>
                                </div>
                            }
                        </div>
                        <div class="gallery-badge">
                            @if (Model.AvailableQuantity > 5)
                            {
                                <span class="badge badge-available">IN STOCK</span>
                            }
                            else if (Model.AvailableQuantity > 0)
                            {
                                <span class="badge badge-lowstock">LOW STOCK</span>
                            }
                            else
                            {
                                <span class="badge badge-outofstock">OUT OF STOCK</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Right Column: Booking Panel -->
                <div class="booking-panel">
                    <div class="booking-card">
                        <!-- Header Info -->
                        <div class="booking-header">
                            <div>
                                <h1 class="product-title-large">@Model.Name</h1>
                                <div class="product-meta">
                                    <span class="sku">SKU: EQ-@Model.Id.ToString("D4")</span>
                                    <span class="separator">|</span>
                                    <div class="rating">
                                        @for (int i = 0; i < 5; i++)
                                        {
                                            if (i < roundedRating)
                                            {
                                                <span class="star-icon material-symbols-outlined" style="color: #fbbf24; font-size: 18px; font-variation-settings: 'FILL' 1;">star</span>
                                            }
                                            else
                                            {
                                                <span class="star-icon material-symbols-outlined" style="color: #cbd5e1; font-size: 18px; font-variation-settings: 'FILL' 1;">star</span>
                                            }
                                        }
                                        <span class="rating-value">@averageRating</span>
                                        <span class="rating-count">(@reviewCount reviews)</span>
                                    </div>
                                </div>
                            </div>
                            <button class="favorite-button-large @(Model.IsFavorite ? "favorite-active" : "")"
                                    data-equipment-id="@Model.Id"
                                    onclick="toggleFavorite(this, @Model.Id)">
                                <span class="material-symbols-outlined">@(Model.IsFavorite ? "favorite" : "favorite_border")</span>
                            </button>
                        </div>

                        <!-- Price -->
                        <div class="price-section">
                            <div class="price-large">
                                <span class="currency">$</span>
                                <span class="amount">@Model.PricePerDay.ToString("N0")</span>
                                <span class="period">/ day</span>
                            </div>
                            <p class="price-note">Free cancellation up to 24h before pickup</p>
                        </div>

                        <!-- Deposit Card -->
                        <div class="deposit-card">
                            <div class="deposit-icon">
                                <span class="material-symbols-outlined">lock</span>
                            </div>
                            <div class="deposit-info">
                                <p class="deposit-title">Refundable Deposit: $@Model.Deposit.ToString("N0")</p>
                                <p class="deposit-note">Held on card, released upon return.</p>
                            </div>
                        </div>

                        <!-- Date Selection -->
                        <div class="date-section">
                            <label class="date-label">Select Rental Dates</label>
                            <div class="calendar">
                                <!-- Calendar Header -->
                                <div class="calendar-header">
                                    <button class="calendar-nav" onclick="changeMonth(-1)">
                                        <span class="material-symbols-outlined">chevron_left</span>
                                    </button>
                                    <span class="calendar-month" id="currentMonth">@DateTime.Now.ToString("MMMM yyyy")</span>
                                    <button class="calendar-nav" onclick="changeMonth(1)">
                                        <span class="material-symbols-outlined">chevron_right</span>
                                    </button>
                                </div>

                                <!-- Calendar Grid -->
                                <div class="calendar-grid" id="calendarGrid"></div>
                            </div>

                            <!-- Инструкции по использованию -->
                            <div style="margin-top: 16px; padding: 12px; background: #f8fafc; border-radius: 8px; font-size: 13px; color: #64748b;">
                                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
                                    <span class="material-symbols-outlined" style="font-size: 18px;">info</span>
                                    <span style="font-weight: 500;">How to select dates:</span>
                                </div>
                                <div style="display: flex; gap: 24px; flex-wrap: wrap;">
                                    <div style="display: flex; align-items: center; gap: 4px;">
                                        <span class="material-symbols-outlined" style="font-size: 16px; color: #3b82f6;">mouse</span>
                                        <span>Left click - Start date</span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 4px;">
                                        <span class="material-symbols-outlined" style="font-size: 16px; color: #3b82f6;">mouse</span>
                                        <span>Right click - End date</span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 4px;">
                                        <span class="material-symbols-outlined" style="font-size: 16px; color: #3b82f6;">touch_app</span>
                                        <span>Tap - Start date</span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 4px;">
                                        <span class="material-symbols-outlined" style="font-size: 16px; color: #3b82f6;">touch_app</span>
                                        <span>Long press - End date</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Calculation -->
                        <div class="calculation"></div>

                        <!-- Actions -->
                        <div class="booking-actions">
                            @if (Model.AvailableQuantity > 0)
                            {
                                <button class="checkout-button" id="checkoutButton" onclick="proceedToCheckout()" disabled style="opacity: 0.5; cursor: not-allowed;">
                                    <span>Proceed to Checkout</span>
                                    <span class="material-symbols-outlined">arrow_forward</span>
                                </button>
                            }
                            else
                            {
                                <button class="checkout-button" disabled style="opacity: 0.5; cursor: not-allowed;">
                                    <span>Out of Stock</span>
                                </button>
                            }
                            <div class="payment-badges">
                                <div class="payment-badge">
                                    <span class="material-symbols-outlined">verified_user</span>
                                    Secure Payment
                                </div>
                                <div class="payment-badge">
                                    <span class="material-symbols-outlined">bolt</span>
                                    Instant Confirm
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Details Tabs Section -->
            <div class="details-section">
                <!-- Tab Headers -->
                <div class="tabs-header">
                    <button class="tab-button active" onclick="showTab('description')">Description</button>
                    <button class="tab-button" onclick="showTab('specifications')">Specifications</button>
                    <button class="tab-button" onclick="showTab('terms')">Rental Terms</button>
                    <button class="tab-button" onclick="showTab('reviews')">Reviews (@reviewCount)</button>
                </div>

                <!-- Tab Content -->
                <div class="tab-content">
                    <!-- Description Tab -->
                    <div id="description-tab" class="description-tab active">
                        <h3 class="tab-title">About the @Model.Name</h3>
                        <p class="tab-text">
                            @(!string.IsNullOrEmpty(Model.Description) ? Model.Description : "No description available for this equipment.")
                        </p>
                    </div>

                    <!-- Specifications Tab -->
                    <div id="specifications-tab" class="specifications-tab" style="display: none;">
                        <h3 class="tab-title">Technical Specifications</h3>
                        <div class="specs-grid">
                            <div class="spec-row">
                                <span class="spec-label">Category</span>
                                <span class="spec-value">@(Model.Category?.Name ?? "Uncategorized")</span>
                            </div>
                            <div class="spec-row">
                                <span class="spec-label">Available Quantity</span>
                                <span class="spec-value">@Model.AvailableQuantity units</span>
                            </div>
                            <div class="spec-row">
                                <span class="spec-label">Deposit Required</span>
                                <span class="spec-value">$@Model.Deposit.ToString("N0")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Rental Terms Tab -->
                    <div id="terms-tab" class="terms-tab" style="display: none;">
                        <h3 class="tab-title">Rental Terms</h3>
                        <ul class="terms-list">
                            <li>Minimum rental period: 1 day</li>
                            <li>Free cancellation up to 24 hours before pickup</li>
                            <li>Late returns subject to additional daily fee</li>
                            <li>Equipment must be returned clean and in working condition</li>
                            <li>Operator must be 18+ years of age</li>
                            <li>Valid ID and security deposit required</li>
                        </ul>
                    </div>

                    <!-- Reviews Tab -->
                    <div id="reviews-tab" class="reviews-tab" style="display: none;">
                        <h3 class="tab-title">Customer Reviews</h3>
                        <div class="reviews-summary">
                            <div class="average-rating">
                                <span class="big-rating">@averageRating</span>
                                <div class="rating">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        if (i < roundedRating)
                                        {
                                            <span class="star-icon material-symbols-outlined" style="color: #fbbf24; font-size: 24px; font-variation-settings: 'FILL' 1;">star</span>
                                        }
                                        else if (i == roundedRating && averageRating.Contains("."))
                                        {
                                            <span class="star-icon material-symbols-outlined" style="color: #fbbf24; font-size: 24px;">star_half</span>
                                        }
                                        else
                                        {
                                            <span class="star-icon material-symbols-outlined" style="color: #cbd5e1; font-size: 24px; font-variation-settings: 'FILL' 1;">star</span>
                                        }
                                    }
                                </div>
                                <span class="total-reviews">Based on @reviewCount reviews</span>
                            </div>
                        </div>

                        <!-- Reviews List -->
                        <div class="reviews-list">
                            @if (Model.Reviews != null && Model.Reviews.Any())
                            {
                                @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                                {
                                    <div class="review-item">
                                        <div class="review-header">
                                            <div class="reviewer-info">
                                                <span class="reviewer-name">@(review.User?.Email?.Split('@')[0] ?? "Anonymous")</span>
                                                <span class="review-date">@review.CreatedAt.ToString("MMMM dd, yyyy")</span>
                                            </div>
                                            <div class="rating">
                                                @for (int i = 0; i < 5; i++)
                                                {
                                                    if (i < review.Rating)
                                                    {
                                                        <span class="star-icon material-symbols-outlined" style="color: #fbbf24; font-size: 16px; font-variation-settings: 'FILL' 1;">star</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="star-icon material-symbols-outlined" style="color: #cbd5e1; font-size: 16px; font-variation-settings: 'FILL' 1;">star</span>
                                                    }
                                                }
                                            </div>
                                        </div>
                                        <p class="review-text">@(review.Comment ?? "No comment provided.")</p>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="no-reviews">No reviews yet for this equipment.</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Included Accessories -->
                <div class="accessories-section">
                    <h4 class="accessories-title">Included with rental</h4>
                    <div class="accessories-list">
                        <span class="accessory-tag">
                            <span class="material-symbols-outlined">verified</span>
                            Safety Manual
                        </span>
                        <span class="accessory-tag">
                            <span class="material-symbols-outlined">support_agent</span>
                            24/7 Support
                        </span>
                        <span class="accessory-tag">
                            <span class="material-symbols-outlined">local_shipping</span>
                            Free Delivery
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
</main>

<script>
    function showTab(tabName) {
        // Hide all tabs
        document.getElementById('description-tab').style.display = 'none';
        document.getElementById('specifications-tab').style.display = 'none';
        document.getElementById('terms-tab').style.display = 'none';
        document.getElementById('reviews-tab').style.display = 'none';

        // Remove active class from all buttons
        document.querySelectorAll('.tab-button').forEach(btn => {
            btn.classList.remove('active');
        });

        // Show selected tab
        document.getElementById(tabName + '-tab').style.display = 'block';

        // Add active class to clicked button
        event.target.classList.add('active');
    }

    function toggleFavorite(button, equipmentId) {
        @if (SignInManager.IsSignedIn(User))
        {
                <text>
                // Получаем anti-forgery token
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                fetch('/Favorites/ToggleFavorite', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ equipmentId: equipmentId })
                })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json();
                })
                .then(data => {
                    if (data.success) {
                        const icon = button.querySelector('.material-symbols-outlined');
                        if (data.isFavorite) {
                            icon.textContent = 'favorite';
                            button.classList.add('favorite-active');
                        } else {
                            icon.textContent = 'favorite_border';
                            button.classList.remove('favorite-active');
                        }
                    } else {
                        console.error('Error:', data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                });
                </text>
        }
        else
        {
                <text>
                window.location.href = '/Identity/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                </text>
        }
    }

</script>
<script>
    let currentDate = new Date();
    let selectedStartDate = null;
    let selectedEndDate = null;
    const equipmentId = @Model.Id;

    // Для определения длинного нажатия на телефонах
    let pressTimer;
    let isLongPress = false;

    // Загружаем забронированные даты для этого оборудования
    let bookedDates = [];

    // Функция для загрузки забронированных дат
    async function loadBookedDates() {
        try {
            const response = await fetch(`/Booking/GetBookedDates?equipmentId=${equipmentId}`);
            if (response.ok) {
                bookedDates = await response.json();
                renderCalendar();
            }
        } catch (error) {
            console.error('Error loading booked dates:', error);
            renderCalendar();
        }
    }

    function renderCalendar() {
        const year = currentDate.getFullYear();
        const month = currentDate.getMonth();

        document.getElementById('currentMonth').textContent =
            currentDate.toLocaleString('default', { month: 'long', year: 'numeric' });

        const firstDay = new Date(year, month, 1);
        const lastDay = new Date(year, month + 1, 0);
        const startDayOfWeek = firstDay.getDay(); // 0 = Sunday

        let calendarHTML = '';

        // Сначала добавляем заголовки дней недели
        const weekdays = ['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa'];
        weekdays.forEach(day => {
            calendarHTML += `<span class="weekday">${day}</span>`;
        });

        // Add empty cells for days before month starts
        for (let i = 0; i < startDayOfWeek; i++) {
            calendarHTML += '<span></span>';
        }

        // Add days of month
        const today = new Date();
        today.setHours(0, 0, 0, 0);

        for (let day = 1; day <= lastDay.getDate(); day++) {
            const date = new Date(year, month, day);
            date.setHours(0, 0, 0, 0);

            const yearStr = date.getFullYear();
            const monthStr = String(date.getMonth() + 1).padStart(2, '0');
            const dayStr = String(date.getDate()).padStart(2, '0');
            const dateString = `${yearStr}-${monthStr}-${dayStr}`;

            const isPast = date < today;
            const isBooked = bookedDates.includes(dateString);

            let classes = 'day';
            if (isPast) classes += ' disabled';
            if (isBooked) classes += ' booked';

            // Проверяем, является ли этот день выбранным
            if (selectedStartDate && selectedEndDate) {
                const startParts = selectedStartDate.split('-');
                const endParts = selectedEndDate.split('-');

                const start = new Date(parseInt(startParts[0]), parseInt(startParts[1]) - 1, parseInt(startParts[2]));
                const end = new Date(parseInt(endParts[0]), parseInt(endParts[1]) - 1, parseInt(endParts[2]));
                start.setHours(0, 0, 0, 0);
                end.setHours(0, 0, 0, 0);

                if (date >= start && date <= end) {
                    if (dateString === selectedStartDate) {
                        classes += ' selected-start';
                    } else if (dateString === selectedEndDate) {
                        classes += ' selected-end';
                    } else {
                        classes += ' selected';
                    }
                }
            } else if (selectedStartDate && dateString === selectedStartDate) {
                classes += ' selected-start';
            }

            calendarHTML += `<span class="${classes}"
                data-date="${dateString}"
                data-day="${day}"
                oncontextmenu="handleRightClick(event, '${dateString}')"
                onclick="handleLeftClick(event, '${dateString}')"
                onmousedown="startPressTimer(event, '${dateString}')"
                onmouseup="cancelPressTimer()"
                onmouseleave="cancelPressTimer()"
                ontouchstart="startPressTimer(event, '${dateString}')"
                ontouchend="handleTouchEnd(event, '${dateString}')"
                ontouchmove="cancelPressTimer()"
                ontouchcancel="cancelPressTimer()">${day}</span>`;
        }

        document.getElementById('calendarGrid').innerHTML = calendarHTML;
        updatePriceCalculation();
        updateCheckoutButton(); // Добавлено
    }

    // Обработчик левого клика (стартовая дата)
    function handleLeftClick(event, dateString) {
        event.preventDefault();
        if (isLongPress) {
            isLongPress = false;
            return;
        }
        selectDate(dateString, 'start');
    }

    // Обработчик правого клика (конечная дата)
    function handleRightClick(event, dateString) {
        event.preventDefault(); // Отключаем стандартное контекстное меню
        selectDate(dateString, 'end');
        return false;
    }

    // Таймер для длинного нажатия
    function startPressTimer(event, dateString) {
        if (event.type === 'mousedown' && event.button !== 0) return; // Только левая кнопка мыши
        if (event.type === 'touchstart') {
            event.preventDefault();
        }

        cancelPressTimer();
        pressTimer = setTimeout(() => {
            isLongPress = true;
            selectDate(dateString, 'end');
        }, 500); // 500ms для длинного нажатия
    }

    function cancelPressTimer() {
        if (pressTimer) {
            clearTimeout(pressTimer);
            pressTimer = null;
        }
    }

    function handleTouchEnd(event, dateString) {
        cancelPressTimer();
        if (!isLongPress) {
            selectDate(dateString, 'start');
        }
        isLongPress = false;
    }

    function selectDate(dateString, type) {
        // Создаем дату правильно, учитывая часовой пояс
        const dateParts = dateString.split('-');
        const year = parseInt(dateParts[0]);
        const month = parseInt(dateParts[1]) - 1; // Месяцы в JS от 0 до 11
        const day = parseInt(dateParts[2]);

        const selectedDate = new Date(year, month, day);
        selectedDate.setHours(0, 0, 0, 0);

        const today = new Date();
        today.setHours(0, 0, 0, 0);

        // Don't allow selecting past dates
        if (selectedDate < today) return;

        // Don't allow selecting booked dates
        if (bookedDates.includes(dateString)) return;

        if (type === 'start') {
            // Set start date
            selectedStartDate = dateString;
            selectedEndDate = null;
            console.log('Selected start date:', selectedStartDate);
        } else if (type === 'end') {
            if (!selectedStartDate) {
                // If no start date, set as start
                selectedStartDate = dateString;
                selectedEndDate = null;
                console.log('Selected start date:', selectedStartDate);
            } else {
                const startParts = selectedStartDate.split('-');
                const startYear = parseInt(startParts[0]);
                const startMonth = parseInt(startParts[1]) - 1;
                const startDay = parseInt(startParts[2]);

                const start = new Date(startYear, startMonth, startDay);
                start.setHours(0, 0, 0, 0);

                const end = new Date(year, month, day);
                end.setHours(0, 0, 0, 0);

                if (end < start) {
                    // If end date is before start date, swap
                    selectedStartDate = dateString;
                    selectedEndDate = null;
                } else {
                    // Check if any dates in range are booked
                    let hasBookedDate = false;
                    const checkDate = new Date(start);
                    while (checkDate <= end) {
                        const checkYear = checkDate.getFullYear();
                        const checkMonth = String(checkDate.getMonth() + 1).padStart(2, '0');
                        const checkDay = String(checkDate.getDate()).padStart(2, '0');
                        const checkDateString = `${checkYear}-${checkMonth}-${checkDay}`;

                        if (bookedDates.includes(checkDateString)) {
                            hasBookedDate = true;
                            break;
                        }
                        checkDate.setDate(checkDate.getDate() + 1);
                    }

                    if (!hasBookedDate) {
                        selectedEndDate = dateString;
                        console.log('Selected end date:', selectedEndDate);
                    } else {
                        alert('Some dates in this range are already booked. Please select a different range.');
                        selectedStartDate = null;
                        selectedEndDate = null;
                    }
                }
            }
        }

        renderCalendar();
    }

    function changeMonth(delta) {
        currentDate.setMonth(currentDate.getMonth() + delta);
        renderCalendar();
    }

    // Функция для обновления состояния кнопки
    function updateCheckoutButton() {
        const checkoutButton = document.getElementById('checkoutButton');
        if (!checkoutButton) return;

        if (selectedStartDate && selectedEndDate) {
            // Обе даты выбраны - разблокируем кнопку
            checkoutButton.disabled = false;
            checkoutButton.style.opacity = '1';
            checkoutButton.style.cursor = 'pointer';
        } else {
            // Даты не выбраны - блокируем кнопку
            checkoutButton.disabled = true;
            checkoutButton.style.opacity = '0.5';
            checkoutButton.style.cursor = 'not-allowed';
        }
    }

    // Функция для перехода к оформлению заказа
    function proceedToCheckout() {
        if (!selectedStartDate || !selectedEndDate) {
            alert('Please select both start and end dates');
            return;
        }

        // Здесь будет переход к странице оформления заказа
        // Например:
        // window.location.href = `/Checkout/Index?equipmentId=${equipmentId}&startDate=${selectedStartDate}&endDate=${selectedEndDate}`;
        console.log('Proceeding to checkout with dates:', selectedStartDate, selectedEndDate);
    }

    function updatePriceCalculation() {
        const calculationDiv = document.querySelector('.calculation');
        if (!calculationDiv) return;

        if (selectedStartDate && selectedEndDate) {
            const startParts = selectedStartDate.split('-');
            const endParts = selectedEndDate.split('-');

            const start = new Date(parseInt(startParts[0]), parseInt(startParts[1]) - 1, parseInt(startParts[2]));
            const end = new Date(parseInt(endParts[0]), parseInt(endParts[1]) - 1, parseInt(endParts[2]));

            start.setHours(0, 0, 0, 0);
            end.setHours(0, 0, 0, 0);

            const diffTime = Math.abs(end - start);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;

            const pricePerDay = @Model.PricePerDay;
            const deposit = @Model.Deposit;
            const serviceFee = 250;

            const rentalTotal = pricePerDay * diffDays;
            const totalDue = rentalTotal + serviceFee + deposit;

            const calculationHTML = `
                <div class="calculation-row">
                    <span>$${pricePerDay.toLocaleString()} x ${diffDays} days</span>
                    <span>$${rentalTotal.toLocaleString()}</span>
                </div>
                <div class="calculation-row">
                    <span>Service Fee</span>
                    <span>$${serviceFee.toLocaleString()}</span>
                </div>
                <div class="calculation-row total">
                    <span>Total Due Now</span>
                    <span class="total-amount">$${totalDue.toLocaleString()}</span>
                </div>
                <p class="calculation-note">(Includes $${deposit.toLocaleString()} refundable deposit)</p>
            `;

            calculationDiv.innerHTML = calculationHTML;
        } else if (selectedStartDate) {
            const pricePerDay = @Model.PricePerDay;
            const deposit = @Model.Deposit;
            const serviceFee = 250;

            const calculationHTML = `
                <div class="calculation-row">
                    <span>$${pricePerDay.toLocaleString()} x 1 day (min)</span>
                    <span>$${pricePerDay.toLocaleString()}</span>
                </div>
                <div class="calculation-row">
                    <span>Service Fee</span>
                    <span>$${serviceFee.toLocaleString()}</span>
                </div>
                <div class="calculation-row total">
                    <span>Total Due Now</span>
                    <span class="total-amount">$${(pricePerDay + serviceFee + deposit).toLocaleString()}</span>
                </div>
                <p class="calculation-note">(Includes $${deposit.toLocaleString()} refundable deposit)</p>
                <p class="calculation-note" style="color: #64748b;">Use right click or long press to select end date</p>
            `;

            calculationDiv.innerHTML = calculationHTML;
        }

        updateCheckoutButton(); // Добавлено
    }

    // Load booked dates when page loads
    document.addEventListener('DOMContentLoaded', function() {
        loadBookedDates();
        updateCheckoutButton(); // Добавлено
    });
</script>
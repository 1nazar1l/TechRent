@using Microsoft.AspNetCore.Identity
@using System.Globalization
@model TechRent.Models.Entities.Equipment
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = Model?.Name ?? "Product Details";
    ViewData["css"] = "product";
    ViewData["nav_pos"] = "left";
    ViewData["header"] = "with_search";
}

<main class="main-content">
    <div class="product-container">
        <!-- Breadcrumbs -->
        <nav class="breadcrumb">
            <a href="@Url.Action("Index", "Home")" class="breadcrumb-link">Главная</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <a href="@Url.Action("Index", "Equipment")" class="breadcrumb-link">Каталог</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span class="breadcrumb-current">@Model?.Category?.Name</span>
        </nav>

        @if (Model != null)
        {
            var approvedReviews = Model.Reviews?.Where(r => r.IsApproved).ToList() ?? new List<TechRent.Models.Entities.Review>();
            var averageRating = approvedReviews.Any()
            ? approvedReviews.Average(r => r.Rating).ToString("F1")
            : "0.0";
            var reviewCount = approvedReviews.Count;
            var roundedRating = approvedReviews.Any()
            ? (int)Math.Round(approvedReviews.Average(r => r.Rating))
            : 0;

            <div class="product-layout">
                <!-- Left Column: Gallery -->
                <div class="product-gallery">
                    <!-- Main Image -->
                    <div class="gallery-main">
                        <div class="gallery-main-image">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" alt="@Model.Name">
                            }
                            else
                            {
                                <div style="width: 100%; height: 400px; background: #f1f5f9; display: flex; align-items: center; justify-content: center;">
                                    <span class="material-symbols-outlined" style="font-size: 80px; color: #94a3b8;">construction</span>
                                </div>
                            }
                        </div>
                        <div class="gallery-badge">
                            @if (Model.AvailableQuantity > 5)
                            {
                                <span class="badge badge-available">В НАЛИЧИИ</span>
                            }
                            else if (Model.AvailableQuantity > 0)
                            {
                                <span class="badge badge-lowstock">МАЛО</span>
                            }
                            else
                            {
                                <span class="badge badge-outofstock">НЕТ В НАЛИЧИИ</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Right Column: Booking Panel -->
                <div class="booking-panel">
                    <div class="booking-card">
                        <!-- Header Info -->
                        <div class="booking-header">
                            <div>
                                <h1 class="product-title-large">@Model.Name</h1>
                                <div class="product-meta">
                                    <span class="sku">SKU: EQ-@Model.Id.ToString("D4")</span>
                                    <span class="separator">|</span>
                                    <div class="rating">
                                        @for (int i = 0; i < 5; i++)
                                        {
                                            if (i < roundedRating)
                                            {
                                                <span class="star-icon material-symbols-outlined" style="color: #fbbf24; font-size: 18px; font-variation-settings: 'FILL' 1;">star</span>
                                            }
                                            else
                                            {
                                                <span class="star-icon material-symbols-outlined" style="color: #cbd5e1; font-size: 18px; font-variation-settings: 'FILL' 1;">star</span>
                                            }
                                        }
                                        <span class="rating-value">@averageRating</span>
                                        <span class="rating-count">(@reviewCount отзывов)</span>
                                    </div>
                                </div>
                            </div>
                            <button class="favorite-button-large @(Model.IsFavorite ? "favorite-active" : "")"
                                    data-equipment-id="@Model.Id"
                                    onclick="toggleFavorite(this, @Model.Id)">
                                <span class="material-symbols-outlined">@(Model.IsFavorite ? "favorite" : "favorite_border")</span>
                            </button>
                        </div>

                        <!-- Price -->
                        <div class="price-section">
                            <div class="price-large">
                                <span class="currency">$</span>
                                <span class="amount">@Model.PricePerDay.ToString("N0")</span>
                                <span class="period">/ день</span>
                            </div>
                            <p class="price-note">Бесплатная отмена за 24 часа до получения</p>
                        </div>

                        <!-- Deposit Card -->
                        <div class="deposit-card">
                            <div class="deposit-icon">
                                <span class="material-symbols-outlined">lock</span>
                            </div>
                            <div class="deposit-info">
                                <p class="deposit-title">Возвратный залог: $@Model.Deposit.ToString("N0")</p>
                                <p class="deposit-note">Удерживается на карте, возвращается после сдачи.</p>
                            </div>
                        </div>

                        <!-- Date Selection -->
                        <div class="date-section">
                            <label class="date-label">Выберите даты аренды</label>
                            <div class="calendar">
                                <!-- Calendar Header -->
                                <div class="calendar-header">
                                    <button class="calendar-nav" onclick="changeMonth(-1)">
                                        <span class="material-symbols-outlined">chevron_left</span>
                                    </button>
                                    <span class="calendar-month" id="currentMonth">@DateTime.Now.ToString("MMMM yyyy")</span>
                                    <button class="calendar-nav" onclick="changeMonth(1)">
                                        <span class="material-symbols-outlined">chevron_right</span>
                                    </button>
                                </div>

                                <!-- Calendar Grid -->
                                <div class="calendar-grid" id="calendarGrid"></div>
                            </div>

                            <!-- Инструкции по использованию -->
                            <div style="margin-top: 16px; padding: 12px; background: #f8fafc; border-radius: 8px; font-size: 13px; color: #64748b;">
                                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
                                    <span class="material-symbols-outlined" style="font-size: 18px;">info</span>
                                    <span style="font-weight: 500;">Как выбрать даты:</span>
                                </div>
                                <div style="display: flex; gap: 24px; flex-wrap: wrap;">
                                    <div style="display: flex; align-items: center; gap: 4px;">
                                        <span class="material-symbols-outlined" style="font-size: 16px; color: #3b82f6;">mouse</span>
                                        <span>Левый клик — дата начала</span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 4px;">
                                        <span class="material-symbols-outlined" style="font-size: 16px; color: #3b82f6;">mouse</span>
                                        <span>Правый клик — дата окончания</span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 4px;">
                                        <span class="material-symbols-outlined" style="font-size: 16px; color: #3b82f6;">touch_app</span>
                                        <span>Нажатие — дата начала</span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 4px;">
                                        <span class="material-symbols-outlined" style="font-size: 16px; color: #3b82f6;">touch_app</span>
                                        <span>Долгое нажатие — дата окончания</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Calculation -->
                        <div class="calculation"></div>

                        <!-- Actions -->
                        <div class="booking-actions">
                            @if (Model.AvailableQuantity > 0)
                            {
                                <button class="checkout-button" id="checkoutButton" onclick="proceedToCheckout()" disabled style="opacity: 0.5; cursor: not-allowed;">
                                    <span>Перейти к оформлению</span>
                                    <span class="material-symbols-outlined">arrow_forward</span>
                                </button>
                            }
                            else
                            {
                                <button class="checkout-button" disabled style="opacity: 0.5; cursor: not-allowed;">
                                    <span>Нет в наличии</span>
                                </button>
                            }
                            <div class="payment-badges">
                                <div class="payment-badge">
                                    <span class="material-symbols-outlined">verified_user</span>
                                    Безопасная оплата
                                </div>
                                <div class="payment-badge">
                                    <span class="material-symbols-outlined">bolt</span>
                                    Мгновенное подтверждение
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Details Tabs Section -->
            <div class="details-section">
                <!-- Tab Headers -->
                <div class="tabs-header">
                    <button class="tab-button active" onclick="showTab('description')">Описание</button>
                    <button class="tab-button" onclick="showTab('specifications')">Характеристики</button>
                    <button class="tab-button" onclick="showTab('terms')">Условия аренды</button>
                    <button class="tab-button" onclick="showTab('reviews')">Отзывы (@reviewCount)</button>
                </div>

                <!-- Tab Content -->
                <div class="tab-content">
                    <!-- Description Tab -->
                    <div id="description-tab" class="description-tab active">
                        <h3 class="tab-title">Об оборудовании @Model.Name</h3>
                        <p class="tab-text">
                            @(!string.IsNullOrEmpty(Model.Description) ? Model.Description : "Описание для этого оборудования недоступно.")
                        </p>
                    </div>

                    <!-- Specifications Tab -->
                    <div id="specifications-tab" class="specifications-tab" style="display: none;">
                        <h3 class="tab-title">Технические характеристики</h3>
                        <div class="specs-grid">
                            <div class="spec-row">
                                <span class="spec-label">Категория</span>
                                <span class="spec-value">@(Model.Category?.Name ?? "Без категории")</span>
                            </div>
                            <div class="spec-row">
                                <span class="spec-label">Доступное количество</span>
                                <span class="spec-value">@Model.AvailableQuantity шт.</span>
                            </div>
                            <div class="spec-row">
                                <span class="spec-label">Залог</span>
                                <span class="spec-value">@Model.Deposit.ToString("N0") ₽</span>
                            </div>
                        </div>
                    </div>

                    <!-- Rental Terms Tab -->
                    <div id="terms-tab" class="terms-tab" style="display: none;">
                        <h3 class="tab-title">Условия аренды</h3>
                        <ul class="terms-list">
                            <li>Минимальный срок аренды: 1 день</li>
                            <li>Бесплатная отмена за 24 часа до получения</li>
                            <li>Просрочка возврата облагается дополнительной дневной платой</li>
                            <li>Оборудование должно быть возвращено чистым и в рабочем состоянии</li>
                            <li>Возраст оператора — от 18 лет</li>
                            <li>Требуется удостоверение личности и залог</li>
                        </ul>
                    </div>

                    <!-- Reviews Tab -->
                    <div id="reviews-tab" class="reviews-tab" style="display: none;">
                        <h3 class="tab-title">Отзывы покупателей</h3>

                        <div class="reviews-summary">
                            <div class="average-rating">
                                <span class="big-rating">@averageRating</span>
                                <div class="rating">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        if (i < roundedRating)
                                        {
                                            <span class="star-icon material-symbols-outlined" style="color: #fbbf24; font-size: 24px; font-variation-settings: 'FILL' 1;">star</span>
                                        }
                                        else if (i == roundedRating && averageRating.Contains("."))
                                        {
                                            <span class="star-icon material-symbols-outlined" style="color: #fbbf24; font-size: 24px;">star_half</span>
                                        }
                                        else
                                        {
                                            <span class="star-icon material-symbols-outlined" style="color: #cbd5e1; font-size: 24px; font-variation-settings: 'FILL' 1;">star</span>
                                        }
                                    }
                                </div>
                                <span class="total-reviews">На основе @reviewCount отзывов</span>
                            </div>
                        </div>

                        <!-- Форма для отзыва (только для авторизованных пользователей) -->
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <div id="reviewFormContainer">
                                @{
                                    var userHasReviewed = Model.Reviews != null && Model.Reviews.Any(r => r.UserId == UserManager.GetUserId(User));
                                }

                                @if (!userHasReviewed)
                                {
                                    <div class="review-form" id="reviewForm">
                                        <h4 class="form-title">Написать отзыв</h4>

                                        <div class="rating-selector">
                                            <label class="rating-label">Ваша оценка</label>
                                            <div class="stars">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <label class="star-label">
                                                        <input type="radio" name="rating" value="@i" style="display: none;">
                                                        <span class="star-icon material-symbols-outlined" style="font-size: 32px; color: #cbd5e1; cursor: pointer;" onmouseover="highlightStars(@i)" onmouseleave="resetStars()" onclick="setRating(@i)">star</span>
                                                    </label>
                                                }
                                            </div>
                                        </div>

                                        <div class="comment-field">
                                            <label for="reviewComment" class="comment-label">Ваш комментарий (необязательно)</label>
                                            <textarea id="reviewComment" class="comment-input" rows="4" placeholder="Поделитесь впечатлениями об оборудовании..."></textarea>
                                        </div>

                                        <button class="submit-review-button" onclick="submitReview()">
                                            <span class="material-symbols-outlined">rate_review</span>
                                            Отправить отзыв
                                        </button>
                                    </div>

                                    <div id="reviewSubmittedMessage" style="display: none; text-align: center; padding: 32px; background: #f0fdf4; border-radius: 12px; margin-bottom: 24px;">
                                        <span class="material-symbols-outlined" style="font-size: 48px; color: #10b981;">check_circle</span>
                                        <h4 style="margin: 16px 0 8px; color: #166534;">Спасибо за ваш отзыв!</h4>
                                        <p style="color: #166534;">Ваше мнение помогает другим покупателям принимать решения.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="already-reviewed" style="text-align: center; padding: 32px; background: #f8fafc; border-radius: 12px; margin-bottom: 24px;">
                                        <span class="material-symbols-outlined" style="font-size: 48px; color: #3b82f6;">rate_review</span>
                                        <h4 style="margin: 16px 0 8px; color: #1e293b;">Вы уже оставили отзыв</h4>
                                        <p style="color: #64748b;">Спасибо, что поделились своим мнением!</p>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="login-to-review" style="text-align: center; padding: 32px; background: #f8fafc; border-radius: 12px; margin-bottom: 24px;">
                                <span class="material-symbols-outlined" style="font-size: 48px; color: #94a3b8;">lock</span>
                                <h4 style="margin: 16px 0 8px; color: #1e293b;">Войдите, чтобы оставить отзыв</h4>
                                <p style="color: #64748b; margin-bottom: 16px;">Поделитесь своим опытом с другими покупателями</p>
                                <a href="/Identity/Account/Login?returnUrl=@Context.Request.Path" class="login-button" style="display: inline-flex; align-items: center; gap: 8px; background: #3b82f6; color: white; padding: 10px 20px; border-radius: 40px; text-decoration: none;">
                                    <span class="material-symbols-outlined">login</span>
                                    Войти
                                </a>
                            </div>
                        }

                        <!-- Reviews List -->
                        <div class="reviews-list">
                            @{
                                var currentUserId = UserManager.GetUserId(User);
                                // Показываем: одобренные всем + неодобренные только автору
                                var visibleReviews = Model.Reviews?
                                    .Where(r => r.IsApproved || r.UserId == currentUserId)
                                    .OrderByDescending(r => r.CreatedAt)
                                    .ToList();
                            }
                            @if (visibleReviews != null && visibleReviews.Any())
                            {
                                @foreach (var review in visibleReviews)
                                {
                                    var isPending = !review.IsApproved && review.UserId == currentUserId;
                                    <div class="review-item @(isPending ? "review-pending" : "")">
                                        <div class="review-header">
                                            <div class="reviewer-info">
                                                <span class="reviewer-name">@(review.User?.Email?.Split('@')[0] ?? "Anonymous")</span>
                                                @if (isPending)
                                                {
                                                    <span class="pending-badge">
                                                        <span class="material-symbols-outlined" style="font-size: 16px;">hourglass_empty</span>
                                                        На проверке
                                                    </span>
                                                }
                                                <span class="review-date">@review.CreatedAt.ToString("MMMM dd, yyyy")</span>
                                            </div>
                                            <div class="rating">
                                                @for (int i = 0; i < 5; i++)
                                                {
                                                    if (i < review.Rating)
                                                    {
                                                        <span class="star-icon material-symbols-outlined" style="color: #fbbf24; font-size: 16px; font-variation-settings: 'FILL' 1;">star</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="star-icon material-symbols-outlined" style="color: #cbd5e1; font-size: 16px; font-variation-settings: 'FILL' 1;">star</span>
                                                    }
                                                }
                                            </div>
                                        </div>
                                        <p class="review-text">@(review.Comment ?? "Комментарий не оставлен.")</p>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="no-reviews">Отзывов пока нет. Будьте первым!</p>
                            }
                        </div>
                    </div>
                
                </div>

                <!-- Included Accessories -->
                <div class="accessories-section">
                    <h4 class="accessories-title">Входит в аренду</h4>
                    <div class="accessories-list">
                        <span class="accessory-tag">
                            <span class="material-symbols-outlined">verified</span>
                            Инструкция по безопасности
                        </span>
                        <span class="accessory-tag">
                            <span class="material-symbols-outlined">support_agent</span>
                            Поддержка 24/7
                        </span>
                        <span class="accessory-tag">
                            <span class="material-symbols-outlined">local_shipping</span>
                            Бесплатная доставка
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
</main>

<script>
    function showTab(tabName) {
        // Hide all tabs
        document.getElementById('description-tab').style.display = 'none';
        document.getElementById('specifications-tab').style.display = 'none';
        document.getElementById('terms-tab').style.display = 'none';
        document.getElementById('reviews-tab').style.display = 'none';

        // Remove active class from all buttons
        document.querySelectorAll('.tab-button').forEach(btn => {
            btn.classList.remove('active');
        });

        // Show selected tab
        document.getElementById(tabName + '-tab').style.display = 'block';

        // Add active class to clicked button
        event.target.classList.add('active');
    }

    function toggleFavorite(button, equipmentId) {
        @if (SignInManager.IsSignedIn(User))
        {
                <text>
                // Получаем anti-forgery token
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                fetch('/Favorites/ToggleFavorite', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ equipmentId: equipmentId })
                })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json();
                })
                .then(data => {
                    if (data.success) {
                        const icon = button.querySelector('.material-symbols-outlined');
                        if (data.isFavorite) {
                            icon.textContent = 'favorite';
                            button.classList.add('favorite-active');
                        } else {
                            icon.textContent = 'favorite_border';
                            button.classList.remove('favorite-active');
                        }
                    } else {
                        console.error('Error:', data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                });
                </text>
        }
        else
        {
                <text>
                window.location.href = '/Identity/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                </text>
        }
    }

</script>
<script>
    let currentDate = new Date();
    let selectedStartDate = null;
    let selectedEndDate = null;
    const equipmentId = @Model.Id;

    // Для определения длинного нажатия на телефонах
    let pressTimer;
    let isLongPress = false;

    // Загружаем забронированные даты для этого оборудования
    let bookedDates = [];

    // Функция для загрузки забронированных дат
    async function loadBookedDates() {
        try {
            const response = await fetch(`/Booking/GetBookedDates?equipmentId=${equipmentId}`);
            if (response.ok) {
                bookedDates = await response.json();
                renderCalendar();
            }
        } catch (error) {
            console.error('Error loading booked dates:', error);
            renderCalendar();
        }
    }

    function renderCalendar() {
        const year = currentDate.getFullYear();
        const month = currentDate.getMonth();

        document.getElementById('currentMonth').textContent =
            currentDate.toLocaleString('default', { month: 'long', year: 'numeric' });

        const firstDay = new Date(year, month, 1);
        const lastDay = new Date(year, month + 1, 0);
        const startDayOfWeek = firstDay.getDay(); // 0 = Sunday

        let calendarHTML = '';

        // Сначала добавляем заголовки дней недели
        const weekdays = ['Вс', 'Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб'];
        weekdays.forEach(day => {
            calendarHTML += `<span class="weekday">${day}</span>`;
        });

        // Add empty cells for days before month starts
        for (let i = 0; i < startDayOfWeek; i++) {
            calendarHTML += '<span></span>';
        }

        // Add days of month
        const today = new Date();
        today.setHours(0, 0, 0, 0);

        for (let day = 1; day <= lastDay.getDate(); day++) {
            const date = new Date(year, month, day);
            date.setHours(0, 0, 0, 0);

            const yearStr = date.getFullYear();
            const monthStr = String(date.getMonth() + 1).padStart(2, '0');
            const dayStr = String(date.getDate()).padStart(2, '0');
            const dateString = `${yearStr}-${monthStr}-${dayStr}`;

            const isPast = date < today;
            const isBooked = bookedDates.includes(dateString);

            let classes = 'day';
            if (isPast) classes += ' disabled';
            if (isBooked) classes += ' booked';

            // Проверяем, является ли этот день выбранным
            if (selectedStartDate && selectedEndDate) {
                const startParts = selectedStartDate.split('-');
                const endParts = selectedEndDate.split('-');

                const start = new Date(parseInt(startParts[0]), parseInt(startParts[1]) - 1, parseInt(startParts[2]));
                const end = new Date(parseInt(endParts[0]), parseInt(endParts[1]) - 1, parseInt(endParts[2]));
                start.setHours(0, 0, 0, 0);
                end.setHours(0, 0, 0, 0);

                if (date >= start && date <= end) {
                    if (dateString === selectedStartDate) {
                        classes += ' selected-start';
                    } else if (dateString === selectedEndDate) {
                        classes += ' selected-end';
                    } else {
                        classes += ' selected';
                    }
                }
            } else if (selectedStartDate && dateString === selectedStartDate) {
                classes += ' selected-start';
            }

            calendarHTML += `<span class="${classes}"
                data-date="${dateString}"
                data-day="${day}"
                oncontextmenu="handleRightClick(event, '${dateString}')"
                onclick="handleLeftClick(event, '${dateString}')"
                onmousedown="startPressTimer(event, '${dateString}')"
                onmouseup="cancelPressTimer()"
                onmouseleave="cancelPressTimer()"
                ontouchstart="startPressTimer(event, '${dateString}')"
                ontouchend="handleTouchEnd(event, '${dateString}')"
                ontouchmove="cancelPressTimer()"
                ontouchcancel="cancelPressTimer()">${day}</span>`;
        }

        document.getElementById('calendarGrid').innerHTML = calendarHTML;
        updatePriceCalculation();
        updateCheckoutButton(); // Добавлено
    }

    // Обработчик левого клика (стартовая дата)
    function handleLeftClick(event, dateString) {
        event.preventDefault();
        if (isLongPress) {
            isLongPress = false;
            return;
        }
        selectDate(dateString, 'start');
    }

    // Обработчик правого клика (конечная дата)
    function handleRightClick(event, dateString) {
        event.preventDefault(); // Отключаем стандартное контекстное меню
        selectDate(dateString, 'end');
        return false;
    }

    // Таймер для длинного нажатия
    function startPressTimer(event, dateString) {
        if (event.type === 'mousedown' && event.button !== 0) return; // Только левая кнопка мыши
        if (event.type === 'touchstart') {
            event.preventDefault();
        }

        cancelPressTimer();
        pressTimer = setTimeout(() => {
            isLongPress = true;
            selectDate(dateString, 'end');
        }, 500); // 500ms для длинного нажатия
    }

    function cancelPressTimer() {
        if (pressTimer) {
            clearTimeout(pressTimer);
            pressTimer = null;
        }
    }

    function handleTouchEnd(event, dateString) {
        cancelPressTimer();
        if (!isLongPress) {
            selectDate(dateString, 'start');
        }
        isLongPress = false;
    }

    function selectDate(dateString, type) {
        // Создаем дату правильно, учитывая часовой пояс
        const dateParts = dateString.split('-');
        const year = parseInt(dateParts[0]);
        const month = parseInt(dateParts[1]) - 1; // Месяцы в JS от 0 до 11
        const day = parseInt(dateParts[2]);

        const selectedDate = new Date(year, month, day);
        selectedDate.setHours(0, 0, 0, 0);

        const today = new Date();
        today.setHours(0, 0, 0, 0);

        // Don't allow selecting past dates
        if (selectedDate < today) return;

        // Don't allow selecting booked dates
        if (bookedDates.includes(dateString)) return;

        if (type === 'start') {
            // Set start date
            selectedStartDate = dateString;
            selectedEndDate = null;
            console.log('Selected start date:', selectedStartDate);
        } else if (type === 'end') {
            if (!selectedStartDate) {
                // If no start date, set as start
                selectedStartDate = dateString;
                selectedEndDate = null;
                console.log('Selected start date:', selectedStartDate);
            } else {
                const startParts = selectedStartDate.split('-');
                const startYear = parseInt(startParts[0]);
                const startMonth = parseInt(startParts[1]) - 1;
                const startDay = parseInt(startParts[2]);

                const start = new Date(startYear, startMonth, startDay);
                start.setHours(0, 0, 0, 0);

                const end = new Date(year, month, day);
                end.setHours(0, 0, 0, 0);

                if (end < start) {
                    // If end date is before start date, swap
                    selectedStartDate = dateString;
                    selectedEndDate = null;
                } else {
                    // Check if any dates in range are booked
                    let hasBookedDate = false;
                    const checkDate = new Date(start);
                    while (checkDate <= end) {
                        const checkYear = checkDate.getFullYear();
                        const checkMonth = String(checkDate.getMonth() + 1).padStart(2, '0');
                        const checkDay = String(checkDate.getDate()).padStart(2, '0');
                        const checkDateString = `${checkYear}-${checkMonth}-${checkDay}`;

                        if (bookedDates.includes(checkDateString)) {
                            hasBookedDate = true;
                            break;
                        }
                        checkDate.setDate(checkDate.getDate() + 1);
                    }

                    if (!hasBookedDate) {
                        selectedEndDate = dateString;
                        console.log('Selected end date:', selectedEndDate);
                    } else {
                        alert('Некоторые даты в этом диапазоне уже забронированы. Выберите другой период.');
                        selectedStartDate = null;
                        selectedEndDate = null;
                    }
                }
            }
        }

        renderCalendar();
    }

    function changeMonth(delta) {
        currentDate.setMonth(currentDate.getMonth() + delta);
        renderCalendar();
    }

    // Функция для обновления состояния кнопки
    function updateCheckoutButton() {
        const checkoutButton = document.getElementById('checkoutButton');
        if (!checkoutButton) return;

        if (selectedStartDate && selectedEndDate) {
            // Обе даты выбраны - разблокируем кнопку
            checkoutButton.disabled = false;
            checkoutButton.style.opacity = '1';
            checkoutButton.style.cursor = 'pointer';
        } else {
            // Даты не выбраны - блокируем кнопку
            checkoutButton.disabled = true;
            checkoutButton.style.opacity = '0.5';
            checkoutButton.style.cursor = 'not-allowed';
        }
    }

    // Функция для перехода к оформлению заказа
    function proceedToCheckout() {
        // Проверяем, авторизован ли пользователь
        @if (!SignInManager.IsSignedIn(User))
        {
                <text>
                // Перенаправляем на страницу регистрации с returnUrl
                const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
                window.location.href = '/Identity/Account/Register?returnUrl=' + returnUrl;
                return;
                </text>
        }

        if (!selectedStartDate || !selectedEndDate) {
            showNotification('Выберите дату начала и окончания аренды', 'error');
            return;
        }

        // Получаем anti-forgery token
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        // Показываем индикатор загрузки
        const button = document.getElementById('checkoutButton');
        const originalText = button.innerHTML;
        button.innerHTML = '<span>Обработка...</span>';
        button.disabled = true;

        // Отправляем запрос на создание бронирования
        fetch('/Booking/CreateBooking', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify({
                equipmentId: equipmentId,
                startDate: selectedStartDate,
                endDate: selectedEndDate
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Меняем кнопку на "View Details"
                button.innerHTML = `
                    <span>Детали бронирования</span>
                    <span class="material-symbols-outlined">visibility</span>
                `;
                button.disabled = false;
                button.onclick = function() {
                    window.location.href = `/Booking/Details/${data.bookingId}`;
                };

                // Показываем успешное уведомление
                showNotification('Бронирование подтверждено! Итого: $' + data.totalAmount.toLocaleString(), 'success');
            } else {
                // Возвращаем кнопку в исходное состояние
                button.innerHTML = originalText;
                button.disabled = false;
                showNotification('Ошибка: ' + data.message, 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            button.innerHTML = originalText;
            button.disabled = false;
            showNotification('Произошла ошибка при создании бронирования', 'error');
        });
    }

        // Функция для показа уведомлений
    function showNotification(message, type) {
        // Создаем элемент уведомления
        const notification = document.createElement('div');
        notification.className = `notification ${type}`;
        notification.innerHTML = `
            <span class="material-symbols-outlined">${type === 'success' ? 'check_circle' : 'error'}</span>
            <span>${message}</span>
        `;

        // Добавляем стили для уведомления
        notification.style.position = 'fixed';
        notification.style.top = '20px';
        notification.style.right = '-400px'; // Начинаем за пределами экрана справа
        notification.style.padding = '12px 24px';
        notification.style.borderRadius = '8px';
        notification.style.backgroundColor = type === 'success' ? '#10b981' : '#ef4444';
        notification.style.color = 'white';
        notification.style.display = 'flex';
        notification.style.alignItems = 'center';
        notification.style.gap = '8px';
        notification.style.zIndex = '1000';
        notification.style.boxShadow = '0 4px 6px rgba(0,0,0,0.1)';
        notification.style.transition = 'right 0.3s ease-in-out';
        notification.style.fontWeight = '500';
        notification.style.minWidth = '300px';
        notification.style.maxWidth = '400px';

        document.body.appendChild(notification);

        // Анимация появления - выезжает справа
        setTimeout(() => {
            notification.style.right = '20px';
        }, 10);

        // Удаляем уведомление через 3 секунды
        setTimeout(() => {
            notification.style.right = '-400px'; // Уезжает вправо
            setTimeout(() => {
                document.body.removeChild(notification);
            }, 300); // Ждем завершения анимации
        }, 3000);
    }

    function updatePriceCalculation() {
        const calculationDiv = document.querySelector('.calculation');
        if (!calculationDiv) return;

        if (selectedStartDate && selectedEndDate) {
            const startParts = selectedStartDate.split('-');
            const endParts = selectedEndDate.split('-');

            const start = new Date(parseInt(startParts[0]), parseInt(startParts[1]) - 1, parseInt(startParts[2]));
            const end = new Date(parseInt(endParts[0]), parseInt(endParts[1]) - 1, parseInt(endParts[2]));

            start.setHours(0, 0, 0, 0);
            end.setHours(0, 0, 0, 0);

            const diffTime = Math.abs(end - start);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;

            const pricePerDay = @Model.PricePerDay;
            const deposit = @Model.Deposit;
            const serviceFee = 250;

            const rentalTotal = pricePerDay * diffDays;
            const totalDue = rentalTotal + serviceFee + deposit;

            const calculationHTML = `
                <div class="calculation-row">
                    <span>$${pricePerDay.toLocaleString()} x ${diffDays} days</span>
                    <span>$${rentalTotal.toLocaleString()}</span>
                </div>
                <div class="calculation-row">
                    <span>Service Fee</span>
                    <span>$${serviceFee.toLocaleString()}</span>
                </div>
                <div class="calculation-row total">
                    <span>Total Due Now</span>
                    <span class="total-amount">$${totalDue.toLocaleString()}</span>
                </div>
                <p class="calculation-note">(Includes $${deposit.toLocaleString()} refundable deposit)</p>
            `;

            calculationDiv.innerHTML = calculationHTML;
        } else if (selectedStartDate) {
            const pricePerDay = @Model.PricePerDay;
            const deposit = @Model.Deposit;
            const serviceFee = 250;

            const calculationHTML = `
                <div class="calculation-row">
                    <span>$${pricePerDay.toLocaleString()} x 1 day (min)</span>
                    <span>$${pricePerDay.toLocaleString()}</span>
                </div>
                <div class="calculation-row">
                    <span>Service Fee</span>
                    <span>$${serviceFee.toLocaleString()}</span>
                </div>
                <div class="calculation-row total">
                    <span>Total Due Now</span>
                    <span class="total-amount">$${(pricePerDay + serviceFee + deposit).toLocaleString()}</span>
                </div>
                <p class="calculation-note">(Includes $${deposit.toLocaleString()} refundable deposit)</p>
                <p class="calculation-note" style="color: #64748b;">Use right click or long press to select end date</p>
            `;

            calculationDiv.innerHTML = calculationHTML;
        }

        updateCheckoutButton(); // Добавлено
    }

    // Load booked dates when page loads
    document.addEventListener('DOMContentLoaded', function() {
        loadBookedDates();
        updateCheckoutButton(); // Добавлено
    });
</script>
<script>
        // Функция для проверки, может ли пользователь оставить отзыв
    async function checkCanReview() {
        @if (SignInManager.IsSignedIn(User))
        {
                <text>
                try {
                    const response = await fetch(`/Review/CanReview?equipmentId=${equipmentId}`);
                    if (response.ok) {
                        const data = await response.json();
                        return data.canReview;
                    }
                } catch (error) {
                    console.error('Error checking review permission:', error);
                }
                return false;
                </text>
        }
        return false;
    }

    // Функция для отправки отзыва
        // Функция для отправки отзыва
    async function submitReview() {
        const rating = document.querySelector('input[name="rating"]:checked')?.value;
        const comment = document.getElementById('reviewComment').value.trim();

        if (!rating) {
            showNotification('Пожалуйста, выберите оценку', 'error');
            return;
        }

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        const submitButton = document.querySelector('.submit-review-button');
        const originalText = submitButton.innerHTML;
        submitButton.innerHTML = '<span>Отправка...</span>';
        submitButton.disabled = true;

        try {
            const response = await fetch('/Review/Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({
                    equipmentId: equipmentId,
                    rating: parseInt(rating),
                    comment: comment
                })
            });

            const data = await response.json();

            if (data.success) {
                showNotification('Отзыв успешно отправлен!', 'success');
                // Скрываем форму
                document.getElementById('reviewForm').style.display = 'none';
                // Показываем сообщение
                document.getElementById('reviewSubmittedMessage').style.display = 'block';
                // Обновляем отзывы на странице
                setTimeout(() => {
                    location.reload();
                }, 2000);
            } else {
                showNotification('Ошибка: ' + data.message, 'error');
                submitButton.innerHTML = originalText;
                submitButton.disabled = false;
            }
        } catch (error) {
            console.error('Error:', error);
            showNotification('Произошла ошибка при отправке отзыва', 'error');
            submitButton.innerHTML = originalText;
            submitButton.disabled = false;
        }
    }

        // Функции для звезд рейтинга
    let currentRating = 0;

    function highlightStars(rating) {
        const stars = document.querySelectorAll('.rating-selector .star-icon');
        stars.forEach((star, index) => {
            if (index < rating) {
                star.style.color = '#fbbf24';
                star.style.fontVariationSettings = "'FILL' 1";
            } else {
                star.style.color = '#cbd5e1';
                star.style.fontVariationSettings = "'FILL' 0";
            }
        });
    }

    function resetStars() {
        const stars = document.querySelectorAll('.rating-selector .star-icon');
        stars.forEach((star, index) => {
            if (index < currentRating) {
                star.style.color = '#fbbf24';
                star.style.fontVariationSettings = "'FILL' 1";
            } else {
                star.style.color = '#cbd5e1';
                star.style.fontVariationSettings = "'FILL' 0";
            }
        });
    }

    function setRating(rating) {
        currentRating = rating;
        const radio = document.querySelector(`input[name="rating"][value="${rating}"]`);
        if (radio) radio.checked = true;
        highlightStars(rating);
    }
</script>
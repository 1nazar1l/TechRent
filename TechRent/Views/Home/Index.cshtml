            </a>
        </div>

        <div class="categories-grid">
            <!-- Category 1 -->
            <a href="#" class="category-card">
                <div class="category-circle">
                    <span class="category-icon material-symbols-outlined">agriculture</span>
                </div>
                <span class="category-name">Земляные работы</span>
            </a>

            <!-- Category 2 -->
            <a href="#" class="category-card">
                <div class="category-circle">
                    <span class="category-icon material-symbols-outlined">foundation</span>
                </div>
                <span class="category-name">Бетонные работы</span>
            </a>

            <!-- Category 3 -->
            <a href="#" class="category-card">
                <div class="category-circle">
                    <span class="category-icon material-symbols-outlined">construction</span>
                </div>
                <span class="category-name">Электроинструменты</span>
            </a>

            <!-- Category 4 -->
            <a href="#" class="category-card">
                <div class="category-circle">
                    <span class="category-icon material-symbols-outlined">forklift</span>
                </div>
                <span class="category-name">Подъёмники</span>
            </a>

            <!-- Category 5 -->
            <a href="#" class="category-card">
                <div class="category-circle">
                    <span class="category-icon material-symbols-outlined">wb_incandescent</span>
                </div>
                <span class="category-name">Освещение</span>
            </a>

            <!-- Category 6 -->
            <a href="#" class="category-card">
                <div class="category-circle">
                    <span class="category-icon material-symbols-outlined">grid_view</span>
                </div>
                <span class="category-name">Все категории</span>
            </a>
        </div>
    </section>

    <!-- How It Works -->
    <section class="how-it-works-section">
        <div class="section-header">
            <h2 class="section-title">Как работает TechRent</h2>
            <p class="section-subtitle">Получите оборудование за 4 простых шага</p>
        </div>

        <div class="steps-container">
            <!-- Connector Line -->
            <div class="connector-line"></div>

            <!-- Step 1 -->
            <div class="step-card">
                <div class="step-icon-wrapper">
                    <span class="step-icon material-symbols-outlined">search</span>
                </div>
                <h3 class="step-title">1. Выберите технику</h3>
                <p class="step-description">Просматривайте тысячи инструментов и тяжёлой техники рядом с вами.</p>
            </div>

            <!-- Step 2 -->
            <div class="step-card">
                <div class="step-icon-wrapper">
                    <span class="step-icon material-symbols-outlined">calendar_today</span>
                </div>
                <h3 class="step-title">2. Выберите даты</h3>
                <p class="step-description">Укажите период аренды. Гибкие почасовые, суточные и недельные тарифы.</p>
            </div>

            <!-- Step 3 -->
            <div class="step-card">
                <div class="step-icon-wrapper">
                    <span class="step-icon material-symbols-outlined">verified_user</span>
                </div>
                <h3 class="step-title">3. Быстрая проверка</h3>
                <p class="step-description">Безопасная онлайн-верификация и оплата. Никакой бумажной волокиты.</p>
            </div>

            <!-- Step 4 -->
            <div class="step-card">
                <div class="step-icon-wrapper">
                    <span class="step-icon material-symbols-outlined">local_shipping</span>
                </div>
                <h3 class="step-title">4. Доставка на объект</h3>
                <p class="step-description">Оборудование доставляется на ваш объект в течение 2 часов или в назначенное время.</p>
            </div>
        </div>
    </section>


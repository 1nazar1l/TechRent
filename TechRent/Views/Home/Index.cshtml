@{
    ViewData["Title"] = "Главная";
    ViewData["css"] = "index";
    ViewData["header"] = "base_header";
}


<!-- Hero Section -->
<section class="hero-section" style='background-image: linear-gradient(rgba(15, 23, 42, 0.75), rgba(15, 23, 42, 0.85)), url("https://lh3.googleusercontent.com/aida-public/AB6AXuAiyPSmWrRWtNQgmoevRsKItl86Qo_KSq4dSrM2Jmi23O5LUlWr1s1GcidzcqJLTbtX2yf5nvFOdBgnsZBcL48jxpXCcL5_gEukPCuZB1NrzouxiLnkH11CyB4vR95TNdGBk7SR0F4QwletoRPay8uDolRSc6pEfVNNoN6oH3UM6iujbAB1BuUAzO4z0WIbgpnofGFDNEkqBqjwOfZLbw4jnxOOFVdP8Jnuz25lm3USr8gfGoRlcA8Rr-qSEqduvf-f-3mqfp3yo38");'>
    <div class="hero-content">
        <div class="live-badge">
            <span class="live-dot"></span>
            <span class="live-text">Инвентарь обновляется в реальном времени</span>
        </div>

        <h1 class="hero-title">
            Арендуйте оборудование без простоев. <span class="highlight">Доставка</span> на объект за 2 часа.
        </h1>

        <p class="hero-description">
            Более 5 000 активных объявлений от проверенных поставщиков. Мгновенное бронирование, прозрачные цены и гарантированные сроки доставки.
        </p>
    </div>

    <!-- Search Bar -->
    <div class="search-wrapper">
        <div class="search-container">
            <!-- What field -->
            <div class="search-field">
                <label class="field-label">
                    <span class="label-text">Что</span>
                    <div class="field-input-wrapper">
                        <span class="field-icon material-symbols-outlined">search</span>
                        <input class="field-input" type="text" placeholder="Экскаватор, дрель, подъёмник...">
                    </div>
                </label>
            </div>

            <!-- When field -->
            <div class="search-field">
                <label class="field-label">
                    <span class="label-text">Когда</span>
                    <div class="field-input-wrapper">
                        <span class="field-icon material-symbols-outlined">calendar_month</span>
                        <input class="field-input" type="text" placeholder="Выберите даты">
                    </div>
                </label>
            </div>

            <!-- Where field -->
            <div class="search-field">
                <label class="field-label">
                    <span class="label-text">Где</span>
                    <div class="field-input-wrapper">
                        <span class="field-icon material-symbols-outlined">location_on</span>
                        <input class="field-input" type="text" placeholder="Индекс или город">
                    </div>
                </label>
            </div>

            <!-- Search Button -->
            <button class="search-button">
                Найти
            </button>
        </div>
    </div>
</section>

<!-- Main Content -->
<main class="content-container">
    <!-- Popular Categories -->
    <section class="mb-20">
        <div class="section-title-wrapper">
            <h2 class="section-title">Популярные категории</h2>
            <a href="#" class="view-all-link">
                Все категории

@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@model TechRent.Models.Entities.ProfileViewModel
@{
    ViewData["Title"] = "Профиль";
    ViewData["css"] = "profile";
}

<div class="profile-layout">
    <!-- Sidebar -->
    <aside class="profile-sidebar">
        <div class="sidebar-content">
            <!-- Logo (mobile visible) -->
            <div class="sidebar-logo">
                <div class="logo-icon">
                    <span class="material-symbols-outlined">precision_manufacturing</span>
                </div>
                <h2 class="logo-text">TECHRENT</h2>
            </div>

            <!-- Navigation -->
            <nav class="sidebar-nav">
                <a asp-controller="Profile" asp-action="Index" class="sidebar-link active">
                    <span class="material-symbols-outlined">calendar_month</span>
                    <span>Мои бронирования</span>
                </a>
                <a asp-controller="Profile" asp-action="Favorites" class="sidebar-link">
                    <span class="material-symbols-outlined">favorite</span>
                    <span>Избранное</span>
                </a>
                <a asp-controller="Profile" asp-action="Settings" class="sidebar-link">
                    <span class="material-symbols-outlined">settings</span>
                    <span>Настройки</span>
                </a>
            </nav>

            <!-- User Profile & Logout -->
            <div class="sidebar-footer">
                <div class="user-info">
                    <div class="user-avatar">
                        @if (!string.IsNullOrEmpty(Model.UserAvatar))
                        {
                            <img src="@Model.UserAvatar" alt="User Avatar">
                        }
                        else
                        {
                            <div class="avatar-placeholder">
                                <span class="material-symbols-outlined">person</span>
                            </div>
                        }
                    </div>
                    <div class="user-details">
                        <p class="user-name">@(Model.UserName ?? "User")</p>
                        <p class="user-badge">@(Model.IsPremium ? "Pro участник" : "Стандартный участник")</p>
                    </div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-button">
                        <span class="material-symbols-outlined">logout</span>
                        Выйти
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="profile-content">
        <div class="profile-container">
            <!-- Page Header -->
            <div class="page-header">
                <div>
                    <h1 class="page-title">Мои бронирования</h1>
                    <p class="page-description">Управляйте активными арендами и просматривайте историю.</p>
                </div>
            </div>

            <!-- Active Rental Section -->
            @if (Model.ActiveBooking != null)
            {
                var daysLeft = (Model.ActiveBooking.EndDate - DateTime.Now).Days;
                var isUrgent = daysLeft <= 1 && daysLeft >= 0;

                <section class="active-rental">
                    <div class="section-header">
                        <h2 class="section-title">
                            <span class="active-dot"></span>
                            Активная аренда
                        </h2>
                    </div>

                    <div class="active-card">
                        @if (isUrgent)
                        {
                            <div class="alert-banner">
                                <span class="material-symbols-outlined">alarm</span>
                                <span class="alert-text">@daysLeft day left! Return by @Model.ActiveBooking.EndDate.ToString("MMM dd")</span>
                            </div>
                        }

                        <div class="active-content">
                            <!-- Image -->
                            <div class="active-image">
                                @if (!string.IsNullOrEmpty(Model.ActiveBooking.Equipment?.ImageUrl))
                                {
                                    <img src="@Model.ActiveBooking.Equipment.ImageUrl" alt="@Model.ActiveBooking.Equipment.Name">
                                }
                                else
                                {
                                    <div style="width: 100%; height: 100%; background: #f1f5f9; display: flex; align-items: center; justify-content: center;">
                                        <span class="material-symbols-outlined" style="font-size: 48px; color: #94a3b8;">construction</span>
                                    </div>
                                }
                            </div>

                            <!-- Content -->
                            <div class="active-details">
                                <div class="active-info">
                                    <div class="active-header">
                                        <span class="status-badge status-active">Активна</span>
                                        <span class="booking-id">ID: #TR-@Model.ActiveBooking.Id.ToString("D4")</span>
                                    </div>
                                    <h3 class="active-title">@Model.ActiveBooking.Equipment?.Name</h3>
                                    <p class="active-description">@(Model.ActiveBooking.Equipment?.Description ?? "Описание недоступно")</p>

                                    <div class="booking-dates">
                                        <div class="date-item">
                                            <span class="date-label">Дата начала</span>
                                            <span class="date-value">@Model.ActiveBooking.StartDate.ToString("MMM dd, yyyy")</span>
                                        </div>
                                        <div class="date-item">
                                            <span class="date-label">Дата окончания</span>
                                            <span class="date-value highlight">@Model.ActiveBooking.EndDate.ToString("MMM dd, yyyy")</span>
                                        </div>
                                        <div class="date-item">
                                            <span class="date-label">Цена за день</span>
                                            <span class="date-value">$@Model.ActiveBooking.Equipment?.PricePerDay.ToString("F0")</span>
                                        </div>
                                        <div class="date-item">
                                            <span class="date-label">Итого</span>
                                            <span class="date-value">$@Model.ActiveBooking.TotalPrice.ToString("F0")</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="active-actions">
                                    <a asp-controller="Booking" asp-action="Details" asp-route-id="@Model.ActiveBooking.Id" class="button-primary">
                                        <span class="material-symbols-outlined">visibility</span>
                                        Подробнее
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            }

            <!-- Two Column Grid -->
            <div class="two-column-section">
                <!-- Upcoming Bookings -->
                <section class="upcoming-section">
                    <h2 class="section-title">Предстоящие бронирования</h2>
                    @if (Model.UpcomingBookings.Any())
                    {
                        <div class="bookings-list">
                            @foreach (var booking in Model.UpcomingBookings)
                            {
                                <div class="booking-item">
                                    <div class="booking-item-image">
                                        @if (!string.IsNullOrEmpty(booking.Equipment?.ImageUrl))
                                        {
                                            <img src="@booking.Equipment.ImageUrl" alt="@booking.Equipment.Name">
                                        }
                                        else
                                        {
                                            <div style="width: 100%; height: 100%; background: #f1f5f9; display: flex; align-items: center; justify-content: center;">
                                                <span class="material-symbols-outlined" style="font-size: 24px; color: #94a3b8;">construction</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="booking-item-content">
                                        <h4 class="booking-item-title">@booking.Equipment?.Name</h4>
                                        <p class="booking-item-meta">Начало @booking.StartDate.ToString("MMM dd") • @((booking.EndDate - booking.StartDate).Days + 1) дн.</p>
                                    </div>
                                    <a asp-controller="Booking" asp-action="Details" asp-route-id="@booking.Id" class="booking-item-arrow">
                                        <span class="material-symbols-outlined">chevron_right</span>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <span class="material-symbols-outlined">calendar_month</span>
                            <p>Нет предстоящих бронирований</p>
                            <a asp-controller="Equipment" asp-action="Index" class="browse-link">Перейти в каталог</a>
                        </div>
                    }
                </section>

                <!-- Rental History -->
                <section class="history-section">
                    <div class="section-header">
                        <h2 class="section-title">История аренд</h2>
                        <a asp-controller="Booking" asp-action="Index" class="view-all-link">Все аренды</a>
                    </div>
                    @if (Model.HistoryBookings.Any())
                    {
                        <div class="history-list">
                            @foreach (var booking in Model.HistoryBookings.Take(3))
                            {
                                <div class="history-item">
                                    <div class="history-item-image">
                                        @if (!string.IsNullOrEmpty(booking.Equipment?.ImageUrl))
                                        {
                                            <img src="@booking.Equipment.ImageUrl" alt="@booking.Equipment.Name">
                                        }
                                        else
                                        {
                                            <div style="width: 100%; height: 100%; background: #f1f5f9; display: flex; align-items: center; justify-content: center;">
                                                <span class="material-symbols-outlined" style="font-size: 24px; color: #94a3b8;">construction</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="history-item-content">
                                        <div>
                                            <h4 class="history-item-title">@booking.Equipment?.Name</h4>
                                            <p class="history-item-meta">Возвращено @booking.EndDate.ToString("MMM dd")</p>
                                        </div>
                                        <div class="history-item-right">
                                            <span class="history-item-price">$@booking.TotalPrice.ToString("F0")</span>
                                            <span class="payment-status paid">
                                                <span class="material-symbols-outlined">check_circle</span>
                                                Оплачено
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <span class="material-symbols-outlined">history</span>
                            <p>История аренд пуста</p>
                        </div>
                    }
                </section>
            </div>
        </div>
    </main>
</div>
<script src="~/js/profile.js"></script>

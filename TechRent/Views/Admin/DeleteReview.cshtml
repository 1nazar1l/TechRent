@model TechRent.Models.Entities.Review
@{
    ViewData["Title"] = "Удалить отзыв";
    ViewData["css"] = "admin";
}

<main class="main-content">
    <div class="wrapper">
        <div class="breadcrumb">
            <a asp-action="Reviews" class="breadcrumb-link">Админ</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span class="breadcrumb-current">Удалить отзыв</span>
        </div>

        <div class="delete-container">
            <div class="delete-card" style="max-width: 500px;">
                <div class="delete-icon">
                    <span class="material-symbols-outlined" style="font-size: 48px; color: #ef4444;">warning</span>
                </div>

                <h1 class="delete-title">Удалить отзыв</h1>

                <p class="delete-text">
                    Вы уверены, что хотите удалить этот отзыв?
                    Это действие нельзя отменить.
                </p>

                <div class="delete-details">
                    <div class="detail-item">
                        <span class="detail-label">ID:</span>
                        <span class="detail-value">#@Model.Id.ToString("D3")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Пользователь:</span>
                        <span class="detail-value">@(Model.User?.Email ?? "Неизвестный пользователь")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Оборудование:</span>
                        <span class="detail-value">@(Model.Equipment?.Name ?? $"Оборудование #{Model.EquipmentId}")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Рейтинг:</span>
                        <span class="detail-value">
                            <div class="rating" style="display: flex; align-items: center; gap: 2px;">
                                @for (int i = 0; i < 5; i++)
                                {
                                    if (i < Model.Rating)
                                    {
                                        <span class="material-symbols-outlined" style="color: #fbbf24; font-size: 18px; font-variation-settings: 'FILL' 1;">star</span>
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined" style="color: #cbd5e1; font-size: 18px; font-variation-settings: 'FILL' 1;">star</span>
                                    }
                                }
                                <span style="margin-left: 4px;">@Model.Rating/5</span>
                            </div>
                        </span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Дата:</span>
                        <span class="detail-value">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                    <div class="detail-item" style="flex-direction: column; align-items: flex-start; gap: 4px;">
                        <span class="detail-label">Комментарий:</span>
                        <span class="detail-value" style="white-space: pre-wrap; word-break: break-word; background: #f8fafc; padding: 12px; border-radius: 8px; width: 100%;">
                            @if (!string.IsNullOrEmpty(Model.Comment))
                            {
                                @Model.Comment
                            }
                            else
                            {
                                <span class="text-muted">Комментарий не оставлен</span>
                            }
                        </span>
                    </div>
                </div>

                <form asp-action="DeleteReview" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="delete-actions">
                        <button type="submit" class="delete-button-confirm">
                            <span class="material-symbols-outlined">delete</span>
                            Удалить навсегда
                        </button>

                        <a asp-action="Reviews" class="delete-button-cancel">
                            <span class="material-symbols-outlined">close</span>
                            Отмена
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>

<style>
    .text-muted {
        color: #94a3b8;
        font-style: italic;
    }

    .rating {
        display: flex;
        align-items: center;
        gap: 2px;
    }
</style>
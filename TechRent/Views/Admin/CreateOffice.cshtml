@model TechRent.Models.Entities.Office
@{
    ViewData["Title"] = "Добавить офис";
    ViewData["css"] = "admin";
}

<main class="main-content">
    <div class="wrapper">
        <div class="breadcrumb">
            <a href="@Url.Action("Offices", "Admin")" class="breadcrumb-link">Офисы</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span class="breadcrumb-current">Добавить офис</span>
        </div>

        <div class="page-header">
            <h1 class="page-title">Добавить офис</h1>
        </div>

        <div class="form-card" style="max-width:700px;">
            <form asp-action="CreateOffice" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-input" placeholder="Название офиса" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Address" class="form-label"></label>
                    <input asp-for="Address" class="form-input" placeholder="Адрес (необязательно)" />
                </div>

                <div style="display:flex; gap:16px;">
                    <div class="form-group" style="flex:1;">
                        <label asp-for="LatitudeString" class="form-label"></label>
                        <input asp-for="LatitudeString" id="latInput" class="form-input" placeholder="55.751574" />
                        <span asp-validation-for="LatitudeString" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label asp-for="LongitudeString" class="form-label"></label>
                        <input asp-for="LongitudeString" id="lngInput" class="form-input" placeholder="37.573856" />
                        <span asp-validation-for="LongitudeString" class="text-danger"></span>
                    </div>
                </div>

                <p style="font-size:13px; color:#64748b; margin-bottom:8px;">
                    <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle;">info</span>
                    Кликните на карте, чтобы выбрать координаты
                </p>
                <div id="pickMap" style="width:100%; height:350px; border-radius:12px; margin-bottom:24px;"></div>

                <div class="form-actions">
                    <button type="submit" class="save-button">
                        <span class="material-symbols-outlined">save</span>
                        Сохранить
                    </button>
                    <a href="@Url.Action("Offices", "Admin")" class="cancel-button">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</main>

<script src="https://api-maps.yandex.ru/2.1/?apikey=0d3a4764-1b1f-41ba-bc00-42c76b73e45f&lang=ru_RU" type="text/javascript"></script>
<script>
    ymaps.ready(function () {
        const map = new ymaps.Map("pickMap", {
            center: [55.751574, 37.573856],
            zoom: 10,
            controls: ['zoomControl', 'searchControl']
        });

        let mark = null;

        function setMark(coords) {
            if (mark) map.geoObjects.remove(mark);
            mark = new ymaps.Placemark(coords, {}, { preset: 'islands#blueHomeCircleIcon', draggable: true });
            mark.events.add('dragend', function () {
                const c = mark.geometry.getCoordinates();
                document.getElementById('latInput').value = c[0].toFixed(6);
                document.getElementById('lngInput').value = c[1].toFixed(6);
            });
            map.geoObjects.add(mark);
            document.getElementById('latInput').value = coords[0].toFixed(6);
            document.getElementById('lngInput').value = coords[1].toFixed(6);
        }

        map.events.add('click', function (e) {
            setMark(e.get('coords'));
        });

        // Если уже есть координаты — показать метку
        const lat = parseFloat(document.getElementById('latInput').value);
        const lng = parseFloat(document.getElementById('lngInput').value);
        if (lat && lng) setMark([lat, lng]);
    });
</script>

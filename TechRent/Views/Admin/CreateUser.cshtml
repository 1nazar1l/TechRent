@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Создать пользователя";
    ViewData["css"] = "admin";
}

@{
    var allRoles = new[] { "User", "Admin" };
}

<main class="main-content">
    <div class="wrapper">
        <div class="breadcrumb">
            <a asp-action="Users" class="breadcrumb-link">Админ</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span class="breadcrumb-current">Создать пользователя</span>
        </div>

        <div class="form-container">
            <div class="form-card" style="max-width: 600px;">
                <div class="form-header">
                    <h1 class="form-title">Создать нового пользователя</h1>
                    <p class="form-subtitle">Добавьте нового пользователя в систему</p>
                </div>

                <form asp-action="CreateUser" method="post" class="edit-form">
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-input" placeholder="Введите адрес электронной почты" required />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Имя пользователя</label>
                        <input type="text" name="username" class="form-input" placeholder="Введите имя пользователя" required />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Пароль</label>
                        <input type="password" name="password" class="form-input" placeholder="Введите пароль" required />
                        <small class="form-text text-muted" style="display: block; margin-top: 4px; color: #64748b;">
                            Пароль должен содержать не менее 6 символов, включая цифру, заглавную и строчную буквы.
                        </small>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Подтвердите пароль</label>
                        <input type="password" name="confirmPassword" class="form-input" placeholder="Повторите пароль" required />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Номер телефона</label>
                        <input type="tel" name="phoneNumber" class="form-input" placeholder="Введите номер телефона (необязательно)" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Роль</label>
                        <select name="role" class="form-select">
                            @foreach (var role in allRoles)
                            {
                                <option value="@role" selected="@(role == "User" ? "selected" : null)">@role</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="toggle" style="justify-content: space-between; width: 100%;">
                            <span class="toggle-text">Email подтверждён</span>
                            <div class="relative">
                                <input type="checkbox" class="toggle-input" name="emailConfirmed" value="true" />
                                <div class="toggle-switch"></div>
                            </div>
                        </label>
                    </div>

                    <div class="form-group">
                        <label class="toggle" style="justify-content: space-between; width: 100%;">
                            <span class="toggle-text">Телефон подтверждён</span>
                            <div class="relative">
                                <input type="checkbox" class="toggle-input" name="phoneNumberConfirmed" value="true" />
                                <div class="toggle-switch"></div>
                            </div>
                        </label>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="save-button">
                            <span class="material-symbols-outlined">add</span>
                            Создать пользователя
                        </button>

                        <a asp-action="Users" class="cancel-button">
                            <span class="material-symbols-outlined">close</span>
                            Отмена
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
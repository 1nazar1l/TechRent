@{
    ViewData["Title"] = "Редактировать пользователя";
    ViewData["css"] = "admin";
}

@inject UserManager<IdentityUser> UserManager

@{
    var roles = await UserManager.GetRolesAsync(Model);
    var currentRole = roles.FirstOrDefault() ?? "User";
    var allRoles = new[] { "Admin", "User" };
}

<main class="main-content">
    <div class="wrapper">
        <div class="breadcrumb">
            <a asp-action="Users" class="breadcrumb-link">Админ</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span class="breadcrumb-current">Редактировать пользователя</span>
        </div>

        <div class="form-container">
            <div class="form-card" style="max-width: 600px;">
                <div class="form-header">
                    <h1 class="form-title">Редактировать пользователя</h1>
                    <p class="form-subtitle">Обновите данные и роль пользователя</p>
                </div>

                <form asp-action="EditUser" method="post" class="edit-form">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input class="form-input" value="@Model.Email" readonly disabled style="background: #f1f5f9;" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Имя пользователя</label>
                        <input class="form-input" value="@Model.UserName" readonly disabled style="background: #f1f5f9;" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Номер телефона</label>
                        <input asp-for="PhoneNumber" class="form-input" placeholder="Введите номер телефона" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Роль</label>
                        <select name="role" class="form-select">
                            @foreach (var role in allRoles)
                            {
                                if (role == currentRole)
                                {
                                    <option value="@role" selected>@role</option>
                                }
                                else
                                {
                                    <option value="@role">@role</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="toggle" style="justify-content: space-between; width: 100%;">
                            <span class="toggle-text">Email подтверждён</span>
                            <div class="relative">
                                <input type="checkbox" class="toggle-input" name="emailConfirmed" value="true" @(Model.EmailConfirmed ? "checked" : "") />
                                <div class="toggle-switch"></div>
                            </div>
                        </label>
                    </div>

                    <div class="form-group">
                        <label class="toggle" style="justify-content: space-between; width: 100%;">
                            <span class="toggle-text">Телефон подтверждён</span>
                            <div class="relative">
                                <input type="checkbox" class="toggle-input" name="phoneNumberConfirmed" value="true" @(Model.PhoneNumberConfirmed ? "checked" : "") />
                                <div class="toggle-switch"></div>
                            </div>
                        </label>
                    </div>

                    <div class="form-group">
                        <label class="toggle" style="justify-content: space-between; width: 100%;">
                            <span class="toggle-text">Двухфакторная аутентификация</span>
                            <div class="relative">
                                <input type="checkbox" class="toggle-input" name="twoFactorEnabled" value="true" @(Model.TwoFactorEnabled ? "checked" : "") />
                                <div class="toggle-switch"></div>
                            </div>
                        </label>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="save-button">
                            <span class="material-symbols-outlined">save</span>
                            Сохранить изменения
                        </button>

                        <a asp-action="Users" class="cancel-button">
                            <span class="material-symbols-outlined">close</span>
                            Отмена
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
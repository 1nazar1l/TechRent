@model IEnumerable<TechRent.Models.Entities.Office>
@{
    ViewData["Title"] = "Офисы";
    ViewData["css"] = "admin";
}

<main class="main-content">
    <div class="wrapper">
        <div class="breadcrumb">
            <a href="#" class="breadcrumb-link">Админ</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span class="breadcrumb-current">Офисы</span>
        </div>

        <div class="page-header">
            <h1 class="page-title">Офисы и точки выдачи</h1>
            <button class="add-button" onclick="location.href='@Url.Action("CreateOffice", "Admin")'">
                <span class="material-symbols-outlined">add</span>
                Добавить офис
            </button>
        </div>

        <div class="admin-layout">
            <section class="table-section" style="width:100%;">
                <div id="officesMap" style="width:100%; height:400px; border-radius:12px; margin-bottom:24px;"></div>

                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Название</th>
                                <th>Адрес</th>
                                <th>Широта</th>
                                <th>Долгота</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var office in Model)
                            {
                                <tr>
                                    <td class="id-cell">@office.Id</td>
                                    <td><strong>@office.Name</strong></td>
                                    <td>@(office.Address ?? "—")</td>
                                    <td>@office.Latitude.ToString("F6")</td>
                                    <td>@office.Longitude.ToString("F6")</td>
                                    <td class="actions-cell">
                                        <div class="action-buttons">
                                            <button class="action-button edit-button" title="Редактировать"
                                                    onclick="location.href='@Url.Action("EditOffice", "Admin", new { id = office.Id })'">
                                                <span class="material-symbols-outlined">edit</span>
                                            </button>
                                            <button class="action-button delete-button" title="Удалить"
                                                    onclick="location.href='@Url.Action("DeleteOffice", "Admin", new { id = office.Id })'">
                                                <span class="material-symbols-outlined">delete</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>
</main>

<script src="https://api-maps.yandex.ru/2.1/?apikey=0d3a4764-1b1f-41ba-bc00-42c76b73e45f&lang=ru_RU" type="text/javascript"></script>
<script>
    const officesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(o => new {
        o.Id, o.Name, o.Latitude, o.Longitude, o.Address
    })));

    ymaps.ready(function () {
        const map = new ymaps.Map("officesMap", {
            center: officesData.length > 0 ? [officesData[0].latitude, officesData[0].longitude] : [55.751574, 37.573856],
            zoom: 10,
            controls: ['zoomControl']
        });

        officesData.forEach(function (office) {
            const mark = new ymaps.Placemark(
                [office.latitude, office.longitude],
                { balloonContent: `<strong>${office.name}</strong><br>${office.address ?? ''}` },
                { preset: 'islands#blueHomeCircleIcon' }
            );
            map.geoObjects.add(mark);
        });
    });
</script>

@model IEnumerable<TechRent.Models.Entities.Equipment>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@{
    ViewData["Title"] = "Каталог";
    ViewData["css"] = "catalog";
    ViewData["nav_pos"] = "left";
    ViewData["header"] = "with_search";
}

<main class="main-content">
    <div class="wrapper">
        <!-- Breadcrumb & Title -->
        <div class="breadcrumb">
            <a href="@Url.Action("Index", "Home")" class="breadcrumb-link">Главная</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span class="breadcrumb-current">Каталог</span>
        </div>
        <h1 class="page-title">Каталог оборудования</h1>
        <p class="page-description">Просматривайте наш широкий выбор строительной техники.</p>

        <!-- Catalog -->
        <div class="catalog">
            <!-- Filters Sidebar -->
            <aside class="filters">
                <div class="filters-header">
                    <h2 class="filters-title">Фильтры</h2>
                    <button class="reset-button" onclick="location.href='@Url.Action("Index")'">Сбросить</button>
                </div>

                <form method="get" id="filterForm">
                    <!-- Search Filter -->
                    <div class="filters-group">
                        <label class="filter-label">Ключевые слова</label>
                        <div class="filter-search">
                            <span class="filter-search-icon material-symbols-outlined">search</span>
                            <input type="text" name="searchString" class="filter-search-input" placeholder="Модель, ID или тип" value="@ViewBag.SearchString">
                        </div>
                    </div>

                    <!-- Categories -->
                    <div class="filters-group">
                        <label class="filter-label">Категория</label>
                        <div class="checkbox-list">
                            @foreach (var item in ViewBag.Categories)
                            {
                                <label class="checkbox-item">
                                    <span class="checkbox-box">
                                        <input type="checkbox" name="categoryIds" class="checkbox-input" value="@item.Category.Id" 
                                               @(ViewBag.SelectedCategoryIds.Contains(item.Category.Id) ? "checked" : "")>
                                        <span class="checkbox-check material-symbols-outlined">check</span>
                                    </span>
                                    <span class="checkbox-text">@item.Category.Name (@item.Count)</span>
                                </label>
                            }
                        </div>
                    </div>

                    <!-- Price Range -->
                    <div class="filters-group">
                        <label class="filter-label">Цена за день</label>
                        <div class="price-slider">
                            <div class="price-inputs">
                                <div class="price-field">
                                    <span class="price-currency">р.</span>
                                    <input type="number" name="minPrice" class="price-input" value="@ViewBag.MinPrice" placeholder="Мин">
                                </div>
                                <span class="price-separator">-</span>
                                <div class="price-field">
                                    <span class="price-currency">р.</span>
                                    <input type="number" name="maxPrice" class="price-input" value="@ViewBag.MaxPrice" placeholder="Макс">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Availability -->
                    <div class="filters-group">
                        <label class="toggle">
                            <span class="toggle-text">Только в наличии</span>
                            <div class="relative">
                                <input type="checkbox" name="inStockOnly" class="toggle-input" value="true" @(ViewBag.InStockOnly == true ? "checked" : "")>
                                <div class="toggle-switch"></div>
                            </div>
                        </label>
                    </div>

                    <!-- Hidden fields -->
                    <input type="hidden" name="sortOrder" value="@ViewBag.SortOrder" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />

                    <!-- Submit button -->
                    <button type="submit" class="save-button" style="width: 100%; margin-top: 16px; justify-content: center;">
                        <span class="material-symbols-outlined">filter_alt</span>
                        Применить фильтры
                    </button>
                </form>
            </aside>

            <!-- Products Section -->
            <section class="products">
                <!-- Toolbar -->
                <div class="toolbar">
                    <div class="results">
                        <span class="results-number">@ViewBag.TotalItems</span>
                        <span class="results-text">позиций найдено</span>
                    </div>

                    <div class="sort">
                        <div class="sort-field">
                            <span class="sort-label">Сортировать по:</span>
                            <select class="sort-select" onchange="changeSortOrder(this.value)">
                                <option value="recommended" selected="@(ViewBag.SortOrder == "recommended")">Рекомендуемые</option>
                                <option value="price_asc" selected="@(ViewBag.SortOrder == "price_asc")">Цена: по возрастанию</option>
                                <option value="price_desc" selected="@(ViewBag.SortOrder == "price_desc")">Цена: по убыванию</option>
                                <option value="rating" selected="@(ViewBag.SortOrder == "rating")">Высокий рейтинг</option>
                                <option value="newest" selected="@(ViewBag.SortOrder == "newest")">Новинки</option>
                            </select>
                        </div>

                        <div class="divider"></div>

                        <div class="view-toggle">
                            <button class="view-button view-button-active">
                                <span class="material-symbols-outlined">grid_view</span>
                            </button>
                            <button class="view-button">
                                <span class="material-symbols-outlined">view_list</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Products Grid -->
                <div class="products-grid">
                    @foreach (var item in Model)
                    {
                        var averageRating = item.Reviews != null && item.Reviews.Any() 
                            ? item.Reviews.Average(r => r.Rating).ToString("F1") 
                            : "0.0";
                        var reviewCount = item.Reviews?.Count ?? 0;
                        
                        <article class="product-card">
                            <div class="product-badge">
                                @if (item.AvailableQuantity > 5)
                                {
                                    <span class="badge badge-available">В наличии</span>
                                }
                                else if (item.AvailableQuantity > 0)
                                {
                                    <span class="badge badge-lowstock">Мало</span>
                                }
                                else
                                {
                                    <span class="badge badge-outofstock">Нет в наличии</span>
                                }
                            </div>
                            <button class="favorite-button @(item.IsFavorite ? "favorite-active" : "")" 
                                    data-equipment-id="@item.Id"
                                    onclick="toggleFavorite(this, @item.Id)">
                                <span class="material-symbols-outlined">@(item.IsFavorite ? "favorite" : "favorite_border")</span>
                            </button>
                            <div class="product-image">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name">
                                }
                                else
                                {
                                    <div style="width: 100%; height: 100%; background: #f1f5f9; display: flex; align-items: center; justify-content: center;">
                                        <span class="material-symbols-outlined" style="font-size: 48px; color: #94a3b8;">construction</span>
                                    </div>
                                }
                                <div class="image-overlay"></div>
                            </div>
                            <div class="product-details">
                                <div class="product-header">
                                    <h3 class="product-title">@item.Name</h3>
                                    <p class="product-description">@(item.Description ?? "Описание недоступно")</p>
                                </div>
                                
                                <!-- Rating -->
                                <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 8px;">
                                    @{
                                        double ratingValue = 0;
                                        if (item.Reviews != null && item.Reviews.Any())
                                        {
                                            ratingValue = item.Reviews.Average(r => r.Rating);
                                        }
                                        int roundedRating = (int)Math.Round(ratingValue);
                                    }
    
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        if (i < roundedRating)
                                        {
                                            <span class="material-symbols-outlined" style="color: #fbbf24; font-size: 18px; font-variation-settings: 'FILL' 1;">star</span>
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined" style="color: #cbd5e1; font-size: 18px; font-variation-settings: 'FILL' 1;">star</span>
                                        }
                                    }
                                    <span style="font-size: 14px; color: #64748b; margin-left: 4px;">(@(item.Reviews?.Count ?? 0) отзывов)</span>
                                </div>
                                
                                <div class="specs">
                                    <div class="spec">
                                        <span class="spec-icon material-symbols-outlined">category</span>
                                        <span>@(item.Category?.Name ?? "Без категории")</span>
                                    </div>
                                    <div class="spec">
                                        <span class="spec-icon material-symbols-outlined">inventory</span>
                                        <span>@item.AvailableQuantity в наличии</span>
                                    </div>
                                </div>
                                
                                <div class="product-footer">
                                    <div class="price">
                                        <span class="price-label">Цена за день</span>
                                        <span class="price-value">@item.PricePerDay бел. руб.<span class="price-period">/день</span></span>
                                    </div>
                                    @if (item.AvailableQuantity > 0)
                                    {
                                        <a href="@Url.Action("Index", "Product", new { id = item.Id })" class="book-button" style="text-decoration: none;">
                                            Арендовать
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="book-button" disabled style="opacity: 0.5; cursor: not-allowed;">Нет в наличии</button>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                </div>

                <!-- Pagination -->
                <div class="pagination">
                    <nav class="pagination-list">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a href="@Url.Action("Index", new { 
                                page = ViewBag.CurrentPage - 1, 
                                pageSize = ViewBag.PageSize,
                                searchString = ViewBag.SearchString,
                                categoryIds = ViewBag.SelectedCategoryIds,
                                minPrice = ViewBag.MinPrice,
                                maxPrice = ViewBag.MaxPrice,
                                inStockOnly = ViewBag.InStockOnly,
                                sortOrder = ViewBag.SortOrder
                            })" class="pagination-link">
                                <span class="sr-only">Назад</span>
                                <span class="material-symbols-outlined">chevron_left</span>
                            </a>
                        }

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            if (i == ViewBag.CurrentPage)
                            {
                                <a href="#" class="pagination-link pagination-link-active">@i</a>
                            }
                            else
                            {
                                <a href="@Url.Action("Index", new { 
                                    page = i, 
                                    pageSize = ViewBag.PageSize,
                                    searchString = ViewBag.SearchString,
                                    categoryIds = ViewBag.SelectedCategoryIds,
                                    minPrice = ViewBag.MinPrice,
                                    maxPrice = ViewBag.MaxPrice,
                                    inStockOnly = ViewBag.InStockOnly,
                                    sortOrder = ViewBag.SortOrder
                                })" class="pagination-link">@i</a>
                            }
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a href="@Url.Action("Index", new { 
                                page = ViewBag.CurrentPage + 1, 
                                pageSize = ViewBag.PageSize,
                                searchString = ViewBag.SearchString,
                                categoryIds = ViewBag.SelectedCategoryIds,
                                minPrice = ViewBag.MinPrice,
                                maxPrice = ViewBag.MaxPrice,
                                inStockOnly = ViewBag.InStockOnly,
                                sortOrder = ViewBag.SortOrder
                            })" class="pagination-link">
                                <span class="sr-only">Вперёд</span>
                                <span class="material-symbols-outlined">chevron_right</span>
                            </a>
                        }
                    </nav>
                </div>
            </section>
        </div>
    </div>
</main>

<script>
    function changeSortOrder(sortOrder) {
        var url = new URL(window.location.href);
        url.searchParams.set('sortOrder', sortOrder);
        url.searchParams.set('page', 1);
        window.location.href = url.toString();
    }

    function toggleFavorite(button, equipmentId) {
        @if (SignInManager.IsSignedIn(User))
        {
            <text>
            // Получаем anti-forgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            
            fetch('/Favorites/ToggleFavorite', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ equipmentId: equipmentId })
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Network response was not ok');
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    const icon = button.querySelector('.material-symbols-outlined');
                    if (data.isFavorite) {
                        icon.textContent = 'favorite';
                        button.classList.add('favorite-active');
                    } else {
                        icon.textContent = 'favorite_border';
                        button.classList.remove('favorite-active');
                    }
                } else {
                    console.error('Error:', data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
            });
            </text>
        }
        else
        {
            <text>
            window.location.href = '/Identity/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
            </text>
        }
    }
</script>

<script>
    // Сворачивание фильтров на мобильных
    function initMobileFilters() {
        const filters = document.querySelector('.filters');
        const filtersHeader = document.querySelector('.filters-header');
        
        if (window.innerWidth <= 767 && filtersHeader) {
            filtersHeader.addEventListener('click', function() {
                filters.classList.toggle('filters-expanded');
            });
        }
    }
    
    // Запускаем при загрузке и при изменении размера окна
    document.addEventListener('DOMContentLoaded', initMobileFilters);
    window.addEventListener('resize', initMobileFilters);
</script>
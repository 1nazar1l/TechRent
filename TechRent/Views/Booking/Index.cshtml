@model IEnumerable<TechRent.Models.Entities.Booking>
@{
    ViewData["Title"] = "My Rentals - TECHRENT";
    ViewData["css"] = "booking";
}

@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

<main class="main-content">
    <div class="rentals-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb">
            <a href="@Url.Action("Index", "Home")" class="breadcrumb-link">Home</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <a href="#" class="breadcrumb-link">Profile</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span class="breadcrumb-current">My Rentals</span>
        </nav>

        <!-- Page Header -->
        <div class="page-header">
            <div>
                <h1 class="page-title">My Rentals</h1>
                <p class="page-description">View all your equipment rentals</p>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <span class="material-symbols-outlined" style="font-size: 64px; color: #94a3b8;">inbox</span>
                <h2>No rentals found</h2>
                <p>You haven't rented any equipment yet.</p>
                <a href="@Url.Action("Index", "Equipment")" class="button-primary">Browse Equipment</a>
            </div>
        }
        else
        {
            <!-- Tabs Navigation -->
            <div class="rentals-tabs">
                <button class="tab-button active" data-tab="all">All Rentals (@Model.Count())</button>
                <button class="tab-button" data-tab="active">Active (@Model.Count(b => b.Status == "Подтверждено" && b.StartDate <= DateTime.Now && b.EndDate >= DateTime.Now))</button>
                <button class="tab-button" data-tab="upcoming">Upcoming (@Model.Count(b => b.Status == "Подтверждено" && b.StartDate > DateTime.Now))</button>
                <button class="tab-button" data-tab="completed">Completed (@Model.Count(b => b.Status == "Подтверждено" && b.EndDate < DateTime.Now))</button>
                <button class="tab-button" data-tab="cancelled">Cancelled (@Model.Count(b => b.Status == "Отменено"))</button>
            </div>

            <!-- Toolbar with Sort -->
            <div class="rentals-toolbar">
                <div class="results-count">
                    <span class="count-number">@Model.Count()</span>
                    <span class="count-text">rentals total</span>
                </div>

                <div class="sort-control">
                    <label for="sort-select" class="sort-label">Sort by:</label>
                    <select id="sort-select" class="sort-select" onchange="sortRentals(this.value)">
                        <option value="newest">Newest first</option>
                        <option value="oldest">Oldest first</option>
                        <option value="price-high">Price: High to Low</option>
                        <option value="price-low">Price: Low to High</option>
                        <option value="duration">Duration: Longest first</option>
                    </select>
                    <span class="sort-icon material-symbols-outlined">unfold_more</span>
                </div>
            </div>

            <!-- Rentals List -->
            <div class="rentals-list" id="rentalsList">
                @foreach (var booking in Model)
                {
                    var daysLeft = (booking.EndDate - DateTime.Now).Days;
                    var isActive = booking.Status == "Подтверждено" && booking.StartDate <= DateTime.Now && booking.EndDate >= DateTime.Now;
                    var isUpcoming = booking.Status == "Подтверждено" && booking.StartDate > DateTime.Now;
                    var isCompleted = booking.Status == "Подтверждено" && booking.EndDate < DateTime.Now;
                    var isCancelled = booking.Status == "Отменено";

                    <div class="rental-card @(isActive ? "active" : isUpcoming ? "upcoming" : isCompleted ? "completed" : isCancelled ? "cancelled" : "")"
                         data-status="@(isActive ? "active" : isUpcoming ? "upcoming" : isCompleted ? "completed" : isCancelled ? "cancelled" : "")"
                         data-start="@booking.StartDate.ToString("yyyy-MM-dd")"
                         data-price="@booking.TotalPrice"
                         data-duration="@((booking.EndDate - booking.StartDate).Days + 1)">

                        <div class="rental-status-bar">
                            @if (isActive && daysLeft <= 1 && daysLeft >= 0)
                            {
                                <span class="status-badge status-urgent">@daysLeft day left</span>
                            }
                            else if (isActive)
                            {
                                <span class="status-badge status-active">Active</span>
                            }
                            else if (isUpcoming)
                            {
                                <span class="status-badge status-upcoming">Upcoming</span>
                            }
                            else if (isCompleted)
                            {
                                <span class="status-badge status-completed">Completed</span>
                            }
                            else if (isCancelled)
                            {
                                <span class="status-badge status-cancelled">Cancelled</span>
                            }
                            <span class="rental-id">#TR-@booking.Id.ToString("D4")</span>
                        </div>

                        <div class="rental-content">
                            <div class="rental-image">
                                @if (!string.IsNullOrEmpty(booking.Equipment?.ImageUrl))
                                {
                                    <img src="@booking.Equipment.ImageUrl" alt="@booking.Equipment.Name">
                                }
                                else
                                {
                                    <div style="width: 100%; height: 100%; background: #f1f5f9; display: flex; align-items: center; justify-content: center;">
                                        <span class="material-symbols-outlined" style="font-size: 48px; color: #94a3b8;">construction</span>
                                    </div>
                                }
                            </div>

                            <div class="rental-info">
                                <div class="rental-header">
                                    <h3 class="rental-title">@(booking.Equipment?.Name ?? "Unknown Equipment")</h3>
                                    <span class="rental-category">@(booking.Equipment?.Category?.Name ?? "Equipment")</span>
                                </div>
                                <p class="rental-description">@(booking.Equipment?.Description ?? "No description available")</p>

                                <div class="rental-dates">
                                    <div class="date-item">
                                        <span class="date-icon material-symbols-outlined">event</span>
                                        <div>
                                            <span class="date-label">Start</span>
                                            <span class="date-value">@booking.StartDate.ToString("MMM dd, yyyy")</span>
                                        </div>
                                    </div>
                                    <div class="date-item">
                                        <span class="date-icon material-symbols-outlined">event_busy</span>
                                        <div>
                                            <span class="date-label">End</span>
                                            <span class="date-value @(isActive && daysLeft <= 1 ? "highlight" : "")">@booking.EndDate.ToString("MMM dd, yyyy")</span>
                                        </div>
                                    </div>
                                    <div class="date-item">
                                        <span class="date-icon material-symbols-outlined">schedule</span>
                                        <div>
                                            <span class="date-label">Duration</span>
                                            <span class="date-value">@((booking.EndDate - booking.StartDate).Days + 1) days</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="rental-footer">
                                    <div class="rental-price">
                                        <span class="price-label">Total</span>
                                        <span class="price-value">$@booking.TotalPrice.ToString("F2")</span>
                                    </div>
                                    <div class="rental-actions">
                                        <a href="@Url.Action("Details", "Booking", new { id = booking.Id })" class="action-link">View Details</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</main>

<script>
    let currentTab = 'all';
    let currentSort = 'newest';

    // Tab switching functionality
    document.addEventListener('DOMContentLoaded', function() {
        const tabButtons = document.querySelectorAll('.tab-button');

        tabButtons.forEach(button => {
            button.addEventListener('click', function() {
                // Remove active class from all tabs
                tabButtons.forEach(btn => btn.classList.remove('active'));
                // Add active class to clicked tab
                this.classList.add('active');

                currentTab = this.dataset.tab;
                filterAndSortRentals();
            });
        });

        // Initial filter
        filterAndSortRentals();
    });

    function filterAndSortRentals() {
        const rentals = document.querySelectorAll('.rental-card');
        const sortSelect = document.getElementById('sort-select');
        currentSort = sortSelect.value;

        // Filter by tab
        rentals.forEach(rental => {
            const status = rental.dataset.status;
            let shouldShow = false;

            switch(currentTab) {
                case 'all':
                    shouldShow = true;
                    break;
                case 'active':
                    shouldShow = status === 'active';
                    break;
                case 'upcoming':
                    shouldShow = status === 'upcoming';
                    break;
                case 'completed':
                    shouldShow = status === 'completed';
                    break;
                case 'cancelled':
                    shouldShow = status === 'cancelled';
                    break;
            }

            rental.style.display = shouldShow ? 'block' : 'none';
        });

        // Sort visible rentals
        const visibleRentals = Array.from(rentals).filter(r => r.style.display !== 'none');
        const container = document.getElementById('rentalsList');

        visibleRentals.sort((a, b) => {
            switch(currentSort) {
                case 'newest':
                    return new Date(b.dataset.start) - new Date(a.dataset.start);
                case 'oldest':
                    return new Date(a.dataset.start) - new Date(b.dataset.start);
                case 'price-high':
                    return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
                case 'price-low':
                    return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
                case 'duration':
                    return parseInt(b.dataset.duration) - parseInt(a.dataset.duration);
                default:
                    return 0;
            }
        });

        // Reorder DOM
        visibleRentals.forEach(rental => {
            container.appendChild(rental);
        });

        // Update counts in tabs
        updateTabCounts();
    }

    function sortRentals(sortValue) {
        currentSort = sortValue;
        filterAndSortRentals();
    }

    function updateTabCounts() {
        const rentals = document.querySelectorAll('.rental-card');
        const counts = {
            all: rentals.length,
            active: Array.from(rentals).filter(r => r.dataset.status === 'active').length,
            upcoming: Array.from(rentals).filter(r => r.dataset.status === 'upcoming').length,
            completed: Array.from(rentals).filter(r => r.dataset.status === 'completed').length,
            cancelled: Array.from(rentals).filter(r => r.dataset.status === 'cancelled').length
        };

        const tabButtons = document.querySelectorAll('.tab-button');
        tabButtons.forEach(button => {
            const tab = button.dataset.tab;
            const currentText = button.textContent.split(' (')[0];
            button.textContent = `${currentText} (${counts[tab]})`;
        });
    }
</script>

<style>
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 24px;
        margin-top: 40px;
    }

        .empty-state h2 {
            font-size: 24px;
            color: #1e293b;
            margin: 16px 0 8px;
        }

        .empty-state p {
            color: #64748b;
            margin-bottom: 24px;
        }

    .button-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #3b82f6;
        color: white;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 40px;
        font-weight: 500;
        transition: background 0.2s;
    }

        .button-primary:hover {
            background: #2563eb;
        }
</style>
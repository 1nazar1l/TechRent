@model TechRent.Models.Entities.Booking
@{
    ViewData["Title"] = "Rental Details - TECHRENT";
    ViewData["css"] = "booking";
}

@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

<main class="main-content">
    <div class="rental-details-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb">
            <a href="@Url.Action("Index", "Home")" class="breadcrumb-link">Home</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <a href="@Url.Action("Index", "Booking")" class="breadcrumb-link">My Rentals</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span class="breadcrumb-current">Rental Details #TR-@Model.Id.ToString("D4")</span>
        </nav>

        @{
            var daysLeft = (Model.EndDate - DateTime.Now).Days;
            var isActive = Model.Status == "Подтверждено" && Model.StartDate <= DateTime.Now && Model.EndDate >= DateTime.Now;
            var isUpcoming = Model.Status == "Подтверждено" && Model.StartDate > DateTime.Now;
            var isCompleted = Model.Status == "Подтверждено" && Model.EndDate < DateTime.Now;
            var isCancelled = Model.Status == "Отменено";
            var totalDays = (Model.EndDate - Model.StartDate).Days + 1;
            var serviceFee = 250;
            var totalAmount = Model.TotalPrice + serviceFee + Model.DepositPaid;
        }

        <!-- Page Header with Status -->
        <div class="details-header">
            <div>
                <h1 class="page-title">Rental Details</h1>
                <p class="booking-reference">Booking Reference: <strong>#TR-@Model.Id.ToString("D4")</strong></p>
            </div>
            <div class="status-badge-group">
                @if (isActive)
                {
                    <span class="status-badge status-active">Active</span>
                    @if (daysLeft <= 1 && daysLeft >= 0)
                    {
                        <span class="status-badge status-urgent">@daysLeft day left</span>
                    }
                }
                else if (isUpcoming)
                {
                    <span class="status-badge status-upcoming">Upcoming</span>
                }
                else if (isCompleted)
                {
                    <span class="status-badge status-completed">Completed</span>
                }
                else if (isCancelled)
                {
                    <span class="status-badge status-cancelled">Cancelled</span>
                }
            </div>
        </div>

        <!-- Main Grid Layout -->
        <div class="details-grid">
            <!-- Left Column - Equipment Info -->
            <div class="equipment-section">
                <div class="equipment-card">
                    <div class="equipment-image">
                        @if (!string.IsNullOrEmpty(Model.Equipment?.ImageUrl))
                        {
                            <img src="@Model.Equipment.ImageUrl" alt="@Model.Equipment.Name">
                        }
                        else
                        {
                            <div style="width: 100%; height: 100%; background: #f1f5f9; display: flex; align-items: center; justify-content: center;">
                                <span class="material-symbols-outlined" style="font-size: 48px; color: #94a3b8;">construction</span>
                            </div>
                        }
                    </div>
                    <div class="equipment-info">
                        <h2 class="equipment-title">@(Model.Equipment?.Name ?? "Unknown Equipment")</h2>
                        <p class="equipment-category">@(Model.Equipment?.Category?.Name ?? "Equipment")</p>
                        <p class="equipment-description">@(Model.Equipment?.Description ?? "No description available")</p>

                        <div class="equipment-specs">
                            <div class="spec-item">
                                <span class="spec-icon material-symbols-outlined">sell</span>
                                <div>
                                    <span class="spec-label">Daily Rate</span>
                                    <span class="spec-value">$@(Model.Equipment?.PricePerDay.ToString("F0") ?? "0")</span>
                                </div>
                            </div>
                            <div class="spec-item">
                                <span class="spec-icon material-symbols-outlined">lock</span>
                                <div>
                                    <span class="spec-label">Deposit</span>
                                    <span class="spec-value">$@Model.DepositPaid.ToString("F0")</span>
                                </div>
                            </div>
                            @if (Model.Equipment?.AvailableQuantity != null)
                            {
                                <div class="spec-item">
                                    <span class="spec-icon material-symbols-outlined">inventory</span>
                                    <div>
                                        <span class="spec-label">Available</span>
                                        <span class="spec-value">@Model.Equipment.AvailableQuantity units</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Rental Summary Card -->
                <div class="summary-card">
                    <h3 class="summary-title">Rental Summary</h3>

                    <div class="summary-grid">
                        <div class="summary-row">
                            <span class="summary-label">Start Date</span>
                            <span class="summary-value">@Model.StartDate.ToString("MMMM dd, yyyy") <span class="time">(10:00 AM)</span></span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-label">End Date</span>
                            <span class="summary-value @(isActive && daysLeft <= 1 ? "highlight" : "")">@Model.EndDate.ToString("MMMM dd, yyyy") <span class="time">(10:00 AM)</span></span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-label">Duration</span>
                            <span class="summary-value">@totalDays days</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-label">Pickup Location</span>
                            <span class="summary-value">TechRent Depot #12, 123 Industrial Ave</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-label">Return Location</span>
                            <span class="summary-value">Same as pickup</span>
                        </div>
                        @if (Model.Delivery != null)
                        {
                            <div class="summary-row">
                                <span class="summary-label">Delivery Address</span>
                                <span class="summary-value">@Model.Delivery.Address</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right Column - Payment & Actions -->
            <div class="payment-section">
                <!-- Payment Breakdown Card -->
                <div class="payment-card">
                    <h3 class="payment-title">Payment Breakdown</h3>

                    <div class="breakdown-list">
                        <div class="breakdown-item">
                            <span>Daily Rate (x@(totalDays) days)</span>
                            <span>$@Model.TotalPrice.ToString("F2")</span>
                        </div>
                        <div class="breakdown-item">
                            <span>Service Fee</span>
                            <span>$@serviceFee.ToString("F2")</span>
                        </div>
                        @if (Model.Delivery?.Cost > 0)
                        {
                            <div class="breakdown-item">
                                <span>Delivery Fee</span>
                                <span>$@Model.Delivery.Cost.ToString("F2")</span>
                            </div>
                        }
                        <div class="breakdown-item deposit">
                            <span>Refundable Deposit</span>
                            <span>$@Model.DepositPaid.ToString("F2")</span>
                        </div>
                        @if (Model.Fine > 0)
                        {
                            <div class="breakdown-item fine">
                                <span>Fine Applied</span>
                                <span>-$@Model.Fine.ToString("F2")</span>
                            </div>
                        }
                        <div class="breakdown-item total">
                            <span>Total Charged</span>
                            <span>$@totalAmount.ToString("F2")</span>
                        </div>
                    </div>

                    <div class="payment-status">
                        <span class="payment-badge @(isCancelled ? "cancelled" : "paid")">
                            <span class="material-symbols-outlined">@(isCancelled ? "cancel" : "check_circle")</span>
                            @(isCancelled ? "Payment Refunded" : "Payment Completed")
                        </span>
                        @if (Model.Fine > 0)
                        {
                            <span class="payment-badge fine">
                                <span class="material-symbols-outlined">warning</span>
                                Fine Applied
                            </span>
                        }
                    </div>
                </div>

                <!-- Delivery Info Card -->
                @if (Model.Delivery != null)
                {
                    <div class="delivery-card">
                        <h3 class="delivery-title">Delivery Information</h3>

                        <div class="delivery-status">
                            <div class="delivery-step completed">
                                <span class="step-dot"></span>
                                <div>
                                    <span class="step-label">Order Confirmed</span>
                                    <span class="step-date">@Model.StartDate.AddDays(-1).ToString("MMM dd, yyyy - h:mm tt")</span>
                                </div>
                            </div>
                            <div class="delivery-step @(Model.Delivery.Status == "Ожидает" ? "active" : "completed")">
                                <span class="step-dot"></span>
                                <div>
                                    <span class="step-label">Out for Delivery</span>
                                    <span class="step-date">
                                        @if (Model.Delivery.Status == "Ожидает")
                                        {
                                            <span>Expected by @Model.Delivery.DeliveryDate.ToString("hh:mm tt")</span>
                                        }
                                        else
                                        {
                                            <span>@Model.Delivery.DeliveryDate.ToString("MMM dd, yyyy - h:mm tt")</span>
                                        }
                                    </span>
                                </div>
                            </div>
                            <div class="delivery-step @(Model.Delivery.Status == "Выполнена" ? "completed" : "pending")">
                                <span class="step-dot"></span>
                                <div>
                                    <span class="step-label">Delivered</span>
                                    <span class="step-date">
                                        @if (Model.Delivery.Status == "Выполнена")
                                        {
                                            <span>@Model.Delivery.DeliveryDate.ToString("MMM dd, yyyy - h:mm tt")</span>
                                        }
                                        else
                                        {
                                            <span>Pending</span>
                                        }
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="delivery-address">
                            <span class="material-symbols-outlined">location_on</span>
                            <span>@Model.Delivery.Address</span>
                        </div>
                    </div>
                }

                <!-- Action Buttons (только для просмотра, без действий) -->
                <div class="action-buttons">
                    <button class="button-secondary" onclick="window.location.href='@Url.Action("Index", "Booking")'">
                        <span class="material-symbols-outlined">arrow_back</span>
                        Back to Rentals
                    </button>
                    <button class="button-secondary" onclick="window.print()">
                        <span class="material-symbols-outlined">receipt_long</span>
                        Print Details
                    </button>
                </div>
            </div>
        </div>

        <!-- Additional Info Section -->
        <div class="additional-section">
            <div class="terms-card">
                <h3 class="terms-title">Rental Terms & Conditions</h3>
                <ul class="terms-list">
                    <li>Late returns subject to additional daily fee of $45</li>
                    <li>Equipment must be returned clean and in working condition</li>
                    <li>Operator must be 18+ years of age with valid ID</li>
                    <li>Deposit will be refunded within 5-7 business days after return</li>
                    <li>Damage waiver included in service fee</li>
                </ul>
            </div>

            <div class="contact-card">
                <h3 class="contact-title">Need Help?</h3>
                <p class="contact-text">Our support team is available 24/7</p>
                <div class="contact-methods">
                    <a href="tel:+18005550123" class="contact-method">
                        <span class="material-symbols-outlined">call</span>
                        <span>+1 (800) 555-0123</span>
                    </a>
                    <a href="#" class="contact-method">
                        <span class="material-symbols-outlined">chat</span>
                        <span>Live Chat</span>
                    </a>
                    <a href="mailto:support@techrent.com" class="contact-method">
                        <span class="material-symbols-outlined">email</span>
                        <span>support@techrent.com</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</main>